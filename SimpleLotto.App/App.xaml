<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="SimpleLotto.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
                <ResourceDictionary Source="Styles/Layout.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <Color x:Key="SlBackground">#101114</Color>
                    <Color x:Key="SlSurface">#191B20</Color>
                    <Color x:Key="SlSurfaceAlt">#22252B</Color>
                    <Color x:Key="SlBorder">#30343C</Color>
                    <Color x:Key="SlText">#F4F4F5</Color>
                    <Color x:Key="SlMutedText">#A3A7B0</Color>
                    <Color x:Key="SlAccent">#0F766E</Color>
                    <Color x:Key="SlAccentText">#FFFFFF</Color>
                    <Color x:Key="SlDanger">#B42318</Color>
                    <Color x:Key="SlSuccess">#FF9933</Color>
                    <Color x:Key="SlWarning">#D97706</Color>
                    <Color x:Key="SlBinEmpty">#ECECEE</Color>
                    <Color x:Key="SlBinLow">#93C5FD</Color>
                    <Color x:Key="SlBinLowStacked">#60A5FA</Color>
                    <Color x:Key="SlBinMedium">#86EFAC</Color>
                    <Color x:Key="SlBinMediumStacked">#4ADE80</Color>
                    <Color x:Key="SlBinHigh">#FF9933</Color>
                    <Color x:Key="SlBinHighStacked">#FB923C</Color>

                    <SolidColorBrush x:Key="SlBackgroundBrush" Color="{ThemeResource SlBackground}"/>
                    <SolidColorBrush x:Key="SlSurfaceBrush" Color="{ThemeResource SlSurface}"/>
                    <SolidColorBrush x:Key="SlSurfaceAltBrush" Color="{ThemeResource SlSurfaceAlt}"/>
                    <SolidColorBrush x:Key="SlBorderBrush" Color="{ThemeResource SlBorder}"/>
                    <SolidColorBrush x:Key="SlTextBrush" Color="{ThemeResource SlText}"/>
                    <SolidColorBrush x:Key="SlMutedTextBrush" Color="{ThemeResource SlMutedText}"/>
                    <SolidColorBrush x:Key="SlAccentBrush" Color="{ThemeResource SlAccent}"/>
                    <SolidColorBrush x:Key="SlAccentTextBrush" Color="{ThemeResource SlAccentText}"/>
                    <SolidColorBrush x:Key="SlDangerBrush" Color="{ThemeResource SlDanger}"/>
                    <SolidColorBrush x:Key="SlSuccessBrush" Color="{ThemeResource SlSuccess}"/>
                    <SolidColorBrush x:Key="SlWarningBrush" Color="{ThemeResource SlWarning}"/>
                    <SolidColorBrush x:Key="SlBinEmptyBrush" Color="{ThemeResource SlBinEmpty}"/>
                    <SolidColorBrush x:Key="SlBinLowBrush" Color="{ThemeResource SlBinLow}"/>
                    <SolidColorBrush x:Key="SlBinLowStackedBrush" Color="{ThemeResource SlBinLowStacked}"/>
                    <SolidColorBrush x:Key="SlBinMediumBrush" Color="{ThemeResource SlBinMedium}"/>
                    <SolidColorBrush x:Key="SlBinMediumStackedBrush" Color="{ThemeResource SlBinMediumStacked}"/>
                    <SolidColorBrush x:Key="SlBinHighBrush" Color="{ThemeResource SlBinHigh}"/>
                    <SolidColorBrush x:Key="SlBinHighStackedBrush" Color="{ThemeResource SlBinHighStacked}"/>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Light">
                    <Color x:Key="SlBackground">#F4F6F8</Color>
                    <Color x:Key="SlSurface">#FFFFFF</Color>
                    <Color x:Key="SlSurfaceAlt">#EEF2F5</Color>
                    <Color x:Key="SlBorder">#D8DEE6</Color>
                    <Color x:Key="SlText">#15171A</Color>
                    <Color x:Key="SlMutedText">#5F6672</Color>
                    <Color x:Key="SlAccent">#0F766E</Color>
                    <Color x:Key="SlAccentText">#FFFFFF</Color>
                    <Color x:Key="SlDanger">#B42318</Color>
                    <Color x:Key="SlSuccess">#FF9933</Color>
                    <Color x:Key="SlWarning">#B45309</Color>
                    <Color x:Key="SlBinEmpty">#ECECEE</Color>
                    <Color x:Key="SlBinLow">#93C5FD</Color>
                    <Color x:Key="SlBinLowStacked">#60A5FA</Color>
                    <Color x:Key="SlBinMedium">#86EFAC</Color>
                    <Color x:Key="SlBinMediumStacked">#4ADE80</Color>
                    <Color x:Key="SlBinHigh">#FF9933</Color>
                    <Color x:Key="SlBinHighStacked">#FB923C</Color>

                    <SolidColorBrush x:Key="SlBackgroundBrush" Color="{ThemeResource SlBackground}"/>
                    <SolidColorBrush x:Key="SlSurfaceBrush" Color="{ThemeResource SlSurface}"/>
                    <SolidColorBrush x:Key="SlSurfaceAltBrush" Color="{ThemeResource SlSurfaceAlt}"/>
                    <SolidColorBrush x:Key="SlBorderBrush" Color="{ThemeResource SlBorder}"/>
                    <SolidColorBrush x:Key="SlTextBrush" Color="{ThemeResource SlText}"/>
                    <SolidColorBrush x:Key="SlMutedTextBrush" Color="{ThemeResource SlMutedText}"/>
                    <SolidColorBrush x:Key="SlAccentBrush" Color="{ThemeResource SlAccent}"/>
                    <SolidColorBrush x:Key="SlAccentTextBrush" Color="{ThemeResource SlAccentText}"/>
                    <SolidColorBrush x:Key="SlDangerBrush" Color="{ThemeResource SlDanger}"/>
                    <SolidColorBrush x:Key="SlSuccessBrush" Color="{ThemeResource SlSuccess}"/>
                    <SolidColorBrush x:Key="SlWarningBrush" Color="{ThemeResource SlWarning}"/>
                    <SolidColorBrush x:Key="SlBinEmptyBrush" Color="{ThemeResource SlBinEmpty}"/>
                    <SolidColorBrush x:Key="SlBinLowBrush" Color="{ThemeResource SlBinLow}"/>
                    <SolidColorBrush x:Key="SlBinLowStackedBrush" Color="{ThemeResource SlBinLowStacked}"/>
                    <SolidColorBrush x:Key="SlBinMediumBrush" Color="{ThemeResource SlBinMedium}"/>
                    <SolidColorBrush x:Key="SlBinMediumStackedBrush" Color="{ThemeResource SlBinMediumStacked}"/>
                    <SolidColorBrush x:Key="SlBinHighBrush" Color="{ThemeResource SlBinHigh}"/>
                    <SolidColorBrush x:Key="SlBinHighStackedBrush" Color="{ThemeResource SlBinHighStacked}"/>
                </ResourceDictionary>

                <ResourceDictionary x:Key="HighContrast">
                    <SolidColorBrush x:Key="SlBackgroundBrush" Color="{ThemeResource SystemColorWindowColor}"/>
                    <SolidColorBrush x:Key="SlSurfaceBrush" Color="{ThemeResource SystemColorWindowColor}"/>
                    <SolidColorBrush x:Key="SlSurfaceAltBrush" Color="{ThemeResource SystemColorWindowColor}"/>
                    <SolidColorBrush x:Key="SlBorderBrush" Color="{ThemeResource SystemColorWindowTextColor}"/>
                    <SolidColorBrush x:Key="SlTextBrush" Color="{ThemeResource SystemColorWindowTextColor}"/>
                    <SolidColorBrush x:Key="SlMutedTextBrush" Color="{ThemeResource SystemColorGrayTextColor}"/>
                    <SolidColorBrush x:Key="SlAccentBrush" Color="{ThemeResource SystemColorHighlightColor}"/>
                    <SolidColorBrush x:Key="SlAccentTextBrush" Color="{ThemeResource SystemColorHighlightTextColor}"/>
                    <SolidColorBrush x:Key="SlDangerBrush" Color="{ThemeResource SystemColorHotlightColor}"/>
                    <SolidColorBrush x:Key="SlSuccessBrush" Color="{ThemeResource SystemColorHighlightColor}"/>
                    <SolidColorBrush x:Key="SlWarningBrush" Color="{ThemeResource SystemColorHighlightColor}"/>
                    <SolidColorBrush x:Key="SlBinEmptyBrush" Color="{ThemeResource SystemColorWindowColor}"/>
                    <SolidColorBrush x:Key="SlBinLowBrush" Color="{ThemeResource SystemColorGrayTextColor}"/>
                    <SolidColorBrush x:Key="SlBinLowStackedBrush" Color="{ThemeResource SystemColorGrayTextColor}"/>
                    <SolidColorBrush x:Key="SlBinMediumBrush" Color="{ThemeResource SystemColorHighlightColor}"/>
                    <SolidColorBrush x:Key="SlBinMediumStackedBrush" Color="{ThemeResource SystemColorHighlightColor}"/>
                    <SolidColorBrush x:Key="SlBinHighBrush" Color="{ThemeResource SystemColorHighlightColor}"/>
                    <SolidColorBrush x:Key="SlBinHighStackedBrush" Color="{ThemeResource SystemColorHighlightColor}"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
