                                               Style="{StaticResource SlCaptionTextStyle}"/>
                                </StackPanel>
                            </Grid>

                            <TabView x:Name="ClosingTabs"
                                     Grid.Row="1"
                                     IsAddTabButtonVisible="False"
                                     CanDragTabs="False"
