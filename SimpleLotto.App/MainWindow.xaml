                        <Grid x:Name="ClosingContent"
                              RowSpacing="16"
                              Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Closing"
                                               Style="{StaticResource SlSectionTitleTextStyle}"/>
                                    <TextBlock Text="Shift balancing keeps sales totals, inventory evidence, and reconciliation separate."
                                               Style="{StaticResource SlCaptionTextStyle}"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Style="{StaticResource SlPanelBorderStyle}">
                                    <StackPanel Spacing="2">
                                        <TextBlock x:Name="ClosingSalesText"
                                                   Text="$0.00"
                                                   Style="{StaticResource SlMetricTextStyle}"/>
                                        <TextBlock Text="Sales"
                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2"
                                        Style="{StaticResource SlPanelBorderStyle}">
                                    <StackPanel Spacing="2">
                                        <TextBlock x:Name="ClosingTicketsText"
                                                   Text="0"
                                                   Style="{StaticResource SlMetricTextStyle}"/>
                                        <TextBlock Text="Tickets"
                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3"
                                        Style="{StaticResource SlPanelBorderStyle}">
                                    <StackPanel Spacing="2">
                                        <TextBlock x:Name="ClosingEvidenceText"
                                                   Text="0 / 0"
                                                   Style="{StaticResource SlMetricTextStyle}"/>
                                        <TextBlock Text="Bins scanned"
                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1"
                                  ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="280"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SlPanelBorderStyle}">
                                    <Grid RowSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Closing Bin Evidence"
                                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                                        <StackPanel Grid.Row="1"
                                                    Orientation="Horizontal"
                                                    Spacing="12">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="3"
                                                        Background="{ThemeResource SlBinHighBrush}"/>
                                                <TextBlock Text="Scanned"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="3"
                                                        Background="{ThemeResource SlBinLowBrush}"/>
                                                <TextBlock Text="Needs scan"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="3"
                                                        BorderBrush="{ThemeResource SlBorderBrush}"
                                                        BorderThickness="1"
                                                        Background="{ThemeResource SlBinEmptyBrush}"/>
                                                <TextBlock Text="Empty"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <GridView x:Name="ClosingBinsGridView"
                                                  Grid.Row="2"
                                                  MinHeight="360"
                                                  SelectionMode="None">
                                            <GridView.ItemContainerStyle>
                                                <Style TargetType="GridViewItem">
                                                    <Setter Property="MinWidth" Value="{StaticResource SlBinTileSize}"/>
                                                    <Setter Property="MinHeight" Value="{StaticResource SlBinTileSize}"/>
                                                    <Setter Property="Margin" Value="4"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                </Style>
                                            </GridView.ItemContainerStyle>
                                            <GridView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsWrapGrid Orientation="Horizontal"
                                                                   MaximumRowsOrColumns="10"/>
                                                </ItemsPanelTemplate>
                                            </GridView.ItemsPanel>
                                            <GridView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="{StaticResource SlBinTileSize}"
                                                            Height="{StaticResource SlBinTileSize}"
                                                            Padding="4,2"
                                                            CornerRadius="6"
                                                            BorderBrush="{Binding BorderBrush}"
                                                            BorderThickness="1"
                                                            Background="{Binding BackgroundBrush}">
                                                        <StackPanel Spacing="0"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding BinText}"
                                                                       Foreground="{Binding ForegroundBrush}"
                                                                       FontSize="14"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Stretch"
                                                                       TextAlignment="Center"/>
                                                            <TextBlock Text="{Binding Status}"
                                                                       Foreground="{Binding ForegroundBrush}"
                                                                       FontSize="10"
                                                                       HorizontalAlignment="Stretch"
                                                                       TextAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxLines="1"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </GridView.ItemTemplate>
                                        </GridView>
                                    </Grid>
                                </Border>
                                <Border Grid.Column="1"
                                        Style="{StaticResource SlPanelBorderStyle}">
                                    <StackPanel Spacing="12">
                                        <Button Content="Start Closing Scan"
                                                HorizontalAlignment="Stretch"
                                                Click="StartClosingScanButton_Click"/>
                                        <TextBlock Text="Scan dialog collects ticket evidence only. Bin scans are ignored during closing collection."
                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                        <TextBlock Text="Closing Email"
                                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                                        <CheckBox x:Name="ClosingEmailSendCheckBox"
                                                  Content="Send closing email"
                                                  Checked="ClosingEmailOptionChanged"
                                                  Unchecked="ClosingEmailOptionChanged"/>
                                        <TextBlock Text="Include"
                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                        <CheckBox x:Name="ClosingEmailShiftSummaryCheckBox"
                                                  Content="Shift summary CSV"
                                                  Checked="ClosingEmailOptionChanged"
                                                  Unchecked="ClosingEmailOptionChanged"/>
                                        <CheckBox x:Name="ClosingEmailInventoryCheckBox"
                                                  Content="Inventory CSV"
                                                  Checked="ClosingEmailOptionChanged"
                                                  Unchecked="ClosingEmailOptionChanged"/>
                                        <CheckBox x:Name="ClosingEmailSalesDetailCheckBox"
                                                  Content="Sales detail CSV"
                                                  Checked="ClosingEmailOptionChanged"
                                                  Unchecked="ClosingEmailOptionChanged"/>
                                        <CheckBox x:Name="ClosingEmailCorrectionsCheckBox"
                                                  Content="Corrections CSV"
                                                  Checked="ClosingEmailOptionChanged"
                                                  Unchecked="ClosingEmailOptionChanged"/>
                                        <CheckBox x:Name="ClosingEmailAnomaliesCheckBox"
                                                  Content="Anomalies CSV"
                                                  Checked="ClosingEmailOptionChanged"
                                                  Unchecked="ClosingEmailOptionChanged"/>
                                        <CheckBox x:Name="ClosingEmailPlacementEventsCheckBox"
                                                  Content="Placement events CSV"
                                                  Checked="ClosingEmailOptionChanged"
                                                  Unchecked="ClosingEmailOptionChanged"/>
                                        <CheckBox x:Name="ClosingEmailBinAssignmentsCheckBox"
                                                  Content="Bin assignments CSV"
                                                  Checked="ClosingEmailOptionChanged"
                                                  Unchecked="ClosingEmailOptionChanged"/>
                                        <CheckBox x:Name="ClosingEmailInitializationCheckBox"
                                                  Content="Initialization CSV"
                                                  Checked="ClosingEmailOptionChanged"
                                                  Unchecked="ClosingEmailOptionChanged"/>
                                        <CheckBox x:Name="ClosingEmailAuditCheckBox"
                                                  Content="Closing audit CSV"
                                                  Checked="ClosingEmailOptionChanged"
                                                  Unchecked="ClosingEmailOptionChanged"/>
                                        <CheckBox x:Name="ClosingEmailPdfCheckBox"
                                                  Content="PDF closing report"
                                                  Checked="ClosingEmailOptionChanged"
                                                  Unchecked="ClosingEmailOptionChanged"/>
                                        <Button x:Name="SaveClosingEmailChoicesButton"
                                                Content="Save email choices"
                                                HorizontalAlignment="Stretch"
                                                Click="SaveClosingEmailChoicesButton_Click"/>
                                        <TextBlock x:Name="ClosingEmailChoicesStatusText"
                                                   Text="Closing email includes all reports."
                                                   Style="{StaticResource SlCaptionTextStyle}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="ClosingStatusText"
                                                   Text="No closing scan session started."
                                                   Foreground="{ThemeResource SlTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid x:Name="SettingsContent"
                              RowSpacing="16"
