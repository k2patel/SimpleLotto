                                                           Minimum="0"
                                                           Value="0"
                                                           SmallChange="1"
                                                           LargeChange="10"
                                                           ValueChanged="ClosingManualTotalBox_ValueChanged"
                                                           HorizontalAlignment="Stretch"/>
                                                <TextBlock Text="Selected Bin"
                                                           Style="{StaticResource SlSectionTitleTextStyle}"/>
                                                <TextBlock x:Name="ClosingBinDetailText"
                                                           Text="Select a bin to view expected game, bundle, and ticket."
                                                           Foreground="{ThemeResource SlTextBrush}"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock x:Name="ClosingStatusText"
                                                           Text="No closing scan session started."
                                                           Foreground="{ThemeResource SlTextBrush}"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock x:Name="ClosingExceptionText"
