                                                        HorizontalAlignment="Stretch"
                                                        IsEnabled="False"
                                                        Click="ResolveClosingIssuesButton_Click"/>
                                                <Button x:Name="FinalizeClosingButton"
                                                        Content="Finalize Shift Closing"
                                                        HorizontalAlignment="Stretch"
                                                        IsEnabled="False"
                                                        Click="FinalizeClosingButton_Click"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
