<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SimpleLotto.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid"
          SizeChanged="RootGrid_SizeChanged"
          Background="{ThemeResource SlBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{ThemeResource SlSurfaceBrush}"
                BorderBrush="{ThemeResource SlBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="40"
                        Height="40"
                        CornerRadius="8"
                        Background="{ThemeResource SlAccentBrush}">
                    <Image Source="ms-appx:///Assets/SimpleLottoLogo64.png"
                           Width="40"
                           Height="40"
                           Stretch="UniformToFill"/>
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="2">
                    <TextBlock Text="SimpleLotto"
                               Style="{StaticResource SlPageTitleTextStyle}"/>
                    <TextBlock Text="Counter sales and shift totals"
                               Style="{StaticResource SlCaptionTextStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="8">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Visibility="{Binding Visibility, ElementName=BinsContent}">
                        <Border Width="96" Style="{StaticResource SlHeaderMetricCardStyle}">
                            <StackPanel Spacing="1">
                                <TextBlock x:Name="BinsTotalText" Text="0" Style="{StaticResource SlMetricTextStyle}"/>
                                <TextBlock Text="Total bins" Style="{StaticResource SlHeaderMetricCaptionTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Width="96" Style="{StaticResource SlHeaderMetricCardStyle}">
                            <StackPanel Spacing="1">
                                <TextBlock x:Name="BinsActiveText" Text="0" Style="{StaticResource SlMetricTextStyle}"/>
                                <TextBlock Text="Active bins" Style="{StaticResource SlHeaderMetricCaptionTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Width="96" Style="{StaticResource SlHeaderMetricCardStyle}">
                            <StackPanel Spacing="1">
                                <TextBlock x:Name="BinsBundleText" Text="0" Style="{StaticResource SlMetricTextStyle}"/>
                                <TextBlock Text="Bundles" Style="{StaticResource SlHeaderMetricCaptionTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Width="108" Style="{StaticResource SlHeaderMetricCardStyle}">
                            <StackPanel Spacing="1">
                                <TextBlock x:Name="BinsShiftSalesText" Text="$0.00" Style="{StaticResource SlMetricTextStyle}"/>
                                <TextBlock Text="Sales" Style="{StaticResource SlHeaderMetricCaptionTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Width="120" Style="{StaticResource SlHeaderMetricCardStyle}">
                            <StackPanel Spacing="1">
                                <TextBlock x:Name="BinsActivatedText" Text="0" Style="{StaticResource SlMetricTextStyle}"/>
                                <TextBlock Text="Activated bundles" Style="{StaticResource SlHeaderMetricCaptionTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Visibility="{Binding Visibility, ElementName=InventoryContent}">
                        <Border Width="132" Style="{StaticResource SlHeaderMetricCardStyle}">
                            <StackPanel Spacing="1">
                                <TextBlock x:Name="InventoryReceivingCountText" Text="0" Style="{StaticResource SlMetricTextStyle}"/>
                                <TextBlock Text="Unopened bundles" Style="{StaticResource SlHeaderMetricCaptionTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Width="132" Style="{StaticResource SlHeaderMetricCardStyle}">
                            <StackPanel Spacing="1">
                                <TextBlock x:Name="InventoryBundleCountText" Text="0" Style="{StaticResource SlMetricTextStyle}"/>
                                <TextBlock Text="Active bin bundles" Style="{StaticResource SlHeaderMetricCaptionTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Visibility="{Binding Visibility, ElementName=ClosingContent}">
                        <Border Width="120" Style="{StaticResource SlHeaderMetricCardStyle}">
                            <StackPanel Spacing="1">
                                <TextBlock x:Name="ClosingSalesText" Text="$0" Style="{StaticResource SlMetricTextStyle}"/>
                                <TextBlock Text="Sales" Style="{StaticResource SlHeaderMetricCaptionTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Width="96" Style="{StaticResource SlHeaderMetricCardStyle}">
                            <StackPanel Spacing="1">
                                <TextBlock x:Name="ClosingTicketsText" Text="0" Style="{StaticResource SlMetricTextStyle}"/>
                                <TextBlock Text="Total tickets" Style="{StaticResource SlHeaderMetricCaptionTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Width="96" Style="{StaticResource SlHeaderMetricCardStyle}">
                            <StackPanel Spacing="1">
                                <TextBlock x:Name="ClosingEvidenceText" Text="0 / 0" Style="{StaticResource SlMetricTextStyle}"/>
                                <TextBlock Text="Bins scanned" Style="{StaticResource SlHeaderMetricCaptionTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Width="82" Style="{StaticResource SlHeaderMetricCardStyle}">
                            <StackPanel Spacing="1">
                                <TextBlock x:Name="ClosingActivatedText" Text="0" Style="{StaticResource SlMetricTextStyle}"/>
                                <TextBlock Text="Activated" Style="{StaticResource SlHeaderMetricCaptionTextStyle}"/>
                            </StackPanel>
                        </Border>
                        <Border Width="110" Style="{StaticResource SlHeaderMetricCardStyle}">
                            <StackPanel Spacing="1">
                                <TextBlock x:Name="ClosingExpectedCashText" Text="$0.00" Style="{StaticResource SlMetricTextStyle}"/>
                                <TextBlock Text="Expected cash" Style="{StaticResource SlHeaderMetricCaptionTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="3"
                            VerticalAlignment="Center"
                            Spacing="4">
                    <Button x:Name="CloseShiftButton"
                            Content="Close Shift"
                            Style="{StaticResource SlShiftActionButtonStyle}"
                            HorizontalAlignment="Stretch"
                            ToolTipService.ToolTip="Close the current shift"
                            Click="CloseShiftButton_Click"/>
                    <Button x:Name="LogoutButton"
                            Content="Logout"
                            Style="{StaticResource SlLogoutActionButtonStyle}"
                            HorizontalAlignment="Stretch"
                            ToolTipService.ToolTip="Log out of SimpleLotto"
                            Click="LogoutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="LicenseBanner"
                Grid.Row="1"
                Visibility="Collapsed"
                Background="#FFFFF4CE"
                BorderBrush="#FFE0A100"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon x:Name="LicenseBannerIcon"
                          Glyph="&#xE7BA;"
                          FontSize="16"
                          Foreground="#FF3B2F00"
                          VerticalAlignment="Center"/>
                <TextBlock x:Name="LicenseBannerText"
                           Grid.Column="1"
                           Text="License status needs attention."
                           Foreground="#FF3B2F00"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="2"
                        Content="Check License"
                        Click="CheckLicenseButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavColumn" Width="190"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{ThemeResource SlSurfaceBrush}"
                    BorderBrush="{ThemeResource SlBorderBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="12">
                <StackPanel Spacing="8">
                    <Grid>
                        <Button x:Name="NavToggleButton"
                                Width="42"
                                Height="32"
                                HorizontalAlignment="Right"
                                Click="NavToggleButton_Click"
                                ToolTipService.ToolTip="Collapse navigation">
                            <FontIcon x:Name="NavToggleIcon"
                                      Glyph="&#xE76B;"
                                      FontSize="16"/>
                        </Button>
                    </Grid>

                    <Button Tag="Dashboard"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Dashboard">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    HorizontalAlignment="Left">
                            <FontIcon Glyph="&#xE80F;" FontSize="16"/>
                            <TextBlock x:Name="DashboardNavLabel" Text="Dashboard" TextAlignment="Left" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Bins"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Bins">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    HorizontalAlignment="Left">
                            <FontIcon Glyph="&#xECA5;" FontSize="16"/>
                            <TextBlock x:Name="BinsNavLabel" Text="Bins" TextAlignment="Left"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Inventory"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Inventory">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    HorizontalAlignment="Left">
                            <FontIcon Glyph="&#xE7B8;" FontSize="16"/>
                            <TextBlock x:Name="InventoryNavLabel" Text="Inventory" TextAlignment="Left"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Closing"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Closing">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    HorizontalAlignment="Left">
                            <FontIcon Glyph="&#xE9D5;" FontSize="16"/>
                            <TextBlock x:Name="ClosingNavLabel" Text="Closing" TextAlignment="Left"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Settings"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Settings">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    HorizontalAlignment="Left">
                            <FontIcon Glyph="&#xE713;" FontSize="16"/>
                            <TextBlock x:Name="SettingsNavLabel" Text="Settings" TextAlignment="Left"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Grid x:Name="DashboardContent"
                  Grid.Column="1"
                  Padding="16"
                  ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource SlPanelBorderStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Scanner"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                        <TextBlock Text="Ready"
                                   Style="{StaticResource SlCaptionTextStyle}"/>
                    </StackPanel>

                    <Border Background="{ThemeResource SlSurfaceAltBrush}"
                            BorderBrush="{ThemeResource SlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="DashboardScannerModeText"
                                       Text="Global scanner"
                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                            <TextBlock x:Name="DashboardScannerStatusText"
                                       Text="Ready for scanner input."
                                       Style="{StaticResource SlCaptionTextStyle}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="DashboardLastScanText"
                                       Text="No scan captured this shift."
                                       Foreground="{ThemeResource SlTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource SlSurfaceAltBrush}"
                            BorderBrush="{ThemeResource SlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Pairing"
                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                            <TextBlock x:Name="DashboardPairingStatusText"
                                       Text="Background capture: not paired"
                                       Style="{StaticResource SlCaptionTextStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource SlPanelBorderStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Sales"
                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                            <TextBlock x:Name="SalesSubtitleText"
                                       Text="No entries yet"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Void Selected"
                                MinWidth="116"
                                Click="VoidSelectedButton_Click"/>
                    </Grid>

                    <Grid Grid.Row="1"
                          Padding="12,8"
                          Background="{ThemeResource SlSurfaceAltBrush}"
                          ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="96"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Time" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="1" Text="Game / Bin" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="2" Text="Tickets" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="3" Text="Amount" Style="{StaticResource SlCaptionTextStyle}"/>
                    </Grid>

                    <ListView x:Name="SalesListView"
                              Grid.Row="2"
                              SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="44"
                                      Padding="12,8"
                                      ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="96"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding TimeText}"
                                               Foreground="{ThemeResource SlMutedTextBrush}"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1"
                                                Spacing="1"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding GameText}"
                                                   Foreground="{ThemeResource SlTextBrush}"/>
                                        <TextBlock Text="{Binding DetailText}"
                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Quantity}"
                                               Foreground="{ThemeResource SlTextBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding AmountText}"
                                               Foreground="{ThemeResource SlTextBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2"
                        Spacing="16">
                <Border Style="{StaticResource SlPanelBorderStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Current Shift"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>

                        <StackPanel Spacing="2">
                            <TextBlock x:Name="RevenueText"
                                       Text="$0.00"
                                       Style="{StaticResource SlMetricTextStyle}"/>
                            <TextBlock Text="Sales amount"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock x:Name="TicketsText"
                                       Text="0"
                                       Style="{StaticResource SlMetricTextStyle}"/>
                            <TextBlock Text="Tickets sold"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SlPanelBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Game Summary"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                        <TextBlock x:Name="GameMixText"
                                   Text="No sales recorded."
                                   Foreground="{ThemeResource SlMutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            </Grid>

            <Grid x:Name="SectionContent"
                  Grid.Column="1"
                  Padding="16"
                  Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid x:Name="BinsContent"
                              RowSpacing="16"
                              Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Bins"
                                               Style="{StaticResource SlSectionTitleTextStyle}"/>
                                    <TextBlock Text="Active and dormant bundle display state. Placement scans assign unplaced bundles; moves are manual from a bin."
                                               Style="{StaticResource SlCaptionTextStyle}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1"
                                  ColumnSpacing="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="BinLayoutColumn" Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition x:Name="BinDetailColumn" Width="320"/>
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource SlPanelBorderStyle}">
                                    <Grid RowSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Working Bin Layout"
                                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                                        <StackPanel Grid.Row="1"
                                                    Orientation="Horizontal"
                                                    Spacing="12">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="3"
                                                        Background="{ThemeResource SlBinLowBrush}"/>
                                                <TextBlock Text="Low"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="3"
                                                        Background="{ThemeResource SlBinMediumBrush}"/>
                                                <TextBlock Text="Medium"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="3"
                                                        Background="{ThemeResource SlBinHighBrush}"/>
                                                <TextBlock Text="High"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="3"
                                                        Background="{ThemeResource SlBinHighStackedBrush}"/>
                                                <TextBlock Text="Multiple = darker shade"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="3"
                                                        BorderBrush="{ThemeResource SlBorderBrush}"
                                                        BorderThickness="1"
                                                        Background="{ThemeResource SlBinEmptyBrush}"/>
                                                <TextBlock Text="Empty"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <GridView x:Name="BinsGridView"
                                                  Grid.Row="2"
                                                  MinHeight="360"
                                                  IsItemClickEnabled="True"
                                                  ItemClick="BinsGridView_ItemClick"
                                                  SelectionMode="None">
                                            <GridView.ItemContainerStyle>
                                                <Style TargetType="GridViewItem">
                                                    <Setter Property="MinWidth" Value="{StaticResource SlBinTileSize}"/>
                                                    <Setter Property="MinHeight" Value="{StaticResource SlBinTileSize}"/>
                                                    <Setter Property="Margin" Value="4"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                </Style>
                                            </GridView.ItemContainerStyle>
                                            <GridView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsWrapGrid Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </GridView.ItemsPanel>
                                            <GridView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="{StaticResource SlBinTileSize}"
                                                            Height="{StaticResource SlBinTileSize}"
                                                            Padding="4,2"
                                                            CornerRadius="6"
                                                            BorderBrush="{Binding BorderBrush}"
                                                            BorderThickness="1"
                                                            Background="{Binding BackgroundBrush}"
                                                            Tapped="BinTile_Tapped">
                                                        <StackPanel Spacing="0"
                                                                    HorizontalAlignment="Stretch"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding BinText}"
                                                                       Foreground="{Binding ForegroundBrush}"
                                                                       FontSize="16"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Stretch"
                                                                       TextAlignment="Center"/>
                                                            <TextBlock Text="{Binding GameTextShort}"
                                                                       Foreground="{Binding ForegroundBrush}"
                                                                       FontSize="12"
                                                                       HorizontalAlignment="Stretch"
                                                                       TextAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxLines="1"
                                                                       Visibility="{Binding GameTextVisibility}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </GridView.ItemTemplate>
                                        </GridView>
                                    </Grid>
                                </Border>

                                <Thumb Grid.Column="1"
                                       Width="8"
                                       DragDelta="BinDetailSplitter_DragDelta">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Grid Background="Transparent">
                                                <Border Width="2"
                                                        HorizontalAlignment="Center"
                                                        Background="{ThemeResource SlBorderBrush}"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>

                                <Border Grid.Column="2"
                                        Style="{StaticResource SlPanelBorderStyle}">
                                    <Grid RowSpacing="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock x:Name="BinDetailText"
                                                   Text="Bin Details (0 bundles)"
                                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                                        <ListView x:Name="BinBundlesListView"
                                                  Grid.Row="1"
                                                  MaxHeight="340"
                                                  Padding="0"
                                                  VerticalAlignment="Top"
                                                  SelectionMode="Single"
                                                  SelectionChanged="BinBundlesListView_SelectionChanged">
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0,0,0,8"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="VerticalContentAlignment" Value="Top"/>
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="10,8"
                                                            CornerRadius="6"
                                                            BorderThickness="1"
                                                            BorderBrush="{Binding CardBorderBrush}"
                                                            Background="{Binding CardBackgroundBrush}">
                                                        <Grid RowSpacing="4"
                                                              ColumnSpacing="8">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{Binding StatusText}"
                                                                       Foreground="{Binding CardForegroundBrush}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="12"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding TicketText}"
                                                                       Foreground="{Binding CardForegroundBrush}"
                                                                       FontSize="12"/>
                                                            <TextBlock Grid.Row="1"
                                                                       Text="{Binding GameIdText}"
                                                                       Foreground="{Binding CardForegroundBrush}"
                                                                       TextWrapping="WrapWholeWords"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxLines="1"/>
                                                            <TextBlock Grid.Row="1"
                                                                       Grid.Column="1"
                                                                       Text="{Binding BundleText}"
                                                                       Foreground="{Binding CardForegroundBrush}"
                                                                       FontSize="12"/>
                                                            <TextBlock Grid.Row="2"
                                                                       Text="{Binding GameNameText}"
                                                                       Foreground="{Binding CardForegroundBrush}"
                                                                       TextWrapping="WrapWholeWords"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxLines="2"/>
                                                            <TextBlock Grid.Row="2"
                                                                       Grid.Column="1"
                                                                       Text="{Binding BinText}"
                                                                       Foreground="{Binding CardForegroundBrush}"
                                                                       FontSize="12"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                        <StackPanel Grid.Row="2"
                                                    Spacing="8">
                                            <Button x:Name="MoveSelectedBundleButton"
                                                    Content="Move Bundle"
                                                    HorizontalAlignment="Stretch"
                                                    Visibility="Collapsed"
                                                    IsEnabled="False"
                                                    Click="MoveSelectedBundleButton_Click"/>
                                            <Button x:Name="AddBundleToBinButton"
                                                    Content="Add Bundle"
                                                    HorizontalAlignment="Stretch"
                                                    IsEnabled="False"
                                                    Click="AddBundleToBinButton_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
