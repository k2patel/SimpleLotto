                                                                Content="Save"
                                                                HorizontalAlignment="Stretch"
                                                                Click="SaveScannerSettingsButton_Click"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="1"
                                                    Style="{StaticResource SlPanelBorderStyle}">
                                                <StackPanel Spacing="10">
                                                    <TextBlock Text="Display"
                                                               Style="{StaticResource SlSectionTitleTextStyle}"/>
                                                    <TextBlock Text="Rdisplay API runs on port 5000 and uses the existing WindowsPOS wire contract."
                                                               Style="{StaticResource SlCaptionTextStyle}"
                                                               TextWrapping="Wrap"/>
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="92"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox x:Name="DisplayHostBox"
                                                                 Header="Display host"
                                                                 PlaceholderText="Pi IP or hostname"/>
                                                        <NumberBox x:Name="DisplayPortBox"
                                                                   Grid.Column="1"
                                                                   Header="Port"
                                                                   Value="5001"
                                                                   Minimum="1"
                                                                   Maximum="65535"
                                                                   SpinButtonPlacementMode="Compact"/>
                                                    </Grid>
                                                    <Button Content="Register Rdisplay"
                                                            HorizontalAlignment="Stretch"
                                                            Click="RegisterDisplayButton_Click"/>
                                                    <TextBlock x:Name="DisplayStatusText"
                                                               Text="No display registered."
                                                               Foreground="{ThemeResource SlTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <Grid Grid.Row="2"
                                              RowSpacing="8">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Registered Displays"
                                                           Style="{StaticResource SlSectionTitleTextStyle}"/>
                                                <TextBlock x:Name="RegisteredDisplaysEmptyText"
                                                           Text="No registered displays yet."
                                                           Style="{StaticResource SlCaptionTextStyle}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ListView x:Name="RegisteredDisplaysListView"
                                                      Grid.Row="1"
                                                      MinHeight="180"
                                                      SelectionMode="None">
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                                        <Setter Property="Padding" Value="0"/>
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="12"
                                                                CornerRadius="8"
                                                                BorderBrush="{ThemeResource SlBorderBrush}"
                                                                BorderThickness="1"
                                                                Background="{ThemeResource SlSurfaceBrush}">
                                                            <Grid ColumnSpacing="12">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="150"/>
                                                                    <ColumnDefinition Width="150"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Spacing="2">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               Foreground="{ThemeResource SlTextBrush}"
                                                                               FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding Endpoint}"
                                                                               Style="{StaticResource SlCaptionTextStyle}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1"
                                                                            Spacing="2">
                                                                    <TextBlock Text="{Binding Status}"
                                                                               Foreground="{ThemeResource SlTextBrush}"/>
                                                                    <TextBlock Text="{Binding ScreenText}"
                                                                               Style="{StaticResource SlCaptionTextStyle}"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="2"
                                                                            Spacing="2">
                                                                    <TextBlock Text="{Binding LastSeenText}"
                                                                               Foreground="{ThemeResource SlTextBrush}"/>
                                                                    <TextBlock Text="{Binding RegisteredText}"
                                                                               Style="{StaticResource SlCaptionTextStyle}"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Grid>
                                    </Grid>
                                </TabViewItem>

                                <TabViewItem x:Name="BackupSettingsTab"
                                             Header="Backup"
                                             IsClosable="False">
                                    <Border Style="{StaticResource SlPanelBorderStyle}">
                                        <StackPanel Spacing="10"
                                                    MaxWidth="620"
                                                    HorizontalAlignment="Left">
                                            <TextBlock Text="Backup"
                                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                                            <TextBox x:Name="BackupFolderBox"
                                                     Header="Backup folder"
                                                     PlaceholderText="USB drive or synced folder path"/>
                                            <Button Content="Backup now"
                                                    HorizontalAlignment="Stretch"
                                                    Click="BackupNowButton_Click"/>
                                            <TextBlock x:Name="BackupStatusText"
                                                       Text="No backup has run."
                                                       Foreground="{ThemeResource SlTextBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </TabViewItem>

                                <TabViewItem x:Name="EmailSettingsTab"
                                             Header="Email"
                                             IsClosable="False">
                                    <Border Style="{StaticResource SlPanelBorderStyle}">
                                        <StackPanel Spacing="10"
                                                    MaxWidth="620"
                                                    HorizontalAlignment="Left">
                                            <TextBlock Text="Email"
                                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                                            <TextBox x:Name="SmtpHostBox"
                                                     Header="SMTP host"/>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <NumberBox x:Name="SmtpPortBox"
                                                           Header="Port"
                                                           Value="587"
                                                           Minimum="1"
                                                           Maximum="65535"
                                                           SpinButtonPlacementMode="Compact"/>
                                                <TextBox x:Name="SmtpUserBox"
                                                         Grid.Column="1"
                                                         Header="SMTP user"/>
                                            </Grid>
                                            <PasswordBox x:Name="SmtpPasswordBox"
                                                         Header="Application password"
                                                         PlaceholderText="Leave blank to keep saved password"/>
                                            <TextBox x:Name="EmailToBox"
                                                     Header="Closing email recipient"/>
                                            <TextBlock Text="Closing email contents"
                                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                                            <CheckBox x:Name="SettingsEmailSendCheckBox"
                                                      Content="Send closing email"
                                                      Checked="SettingsEmailOptionChanged"
                                                      Unchecked="SettingsEmailOptionChanged"/>
                                            <Grid ColumnSpacing="16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="4">
                                                    <CheckBox x:Name="SettingsEmailShiftSummaryCheckBox"
                                                              Content="Shift summary CSV"
                                                              Checked="SettingsEmailOptionChanged"
                                                              Unchecked="SettingsEmailOptionChanged"/>
                                                    <CheckBox x:Name="SettingsEmailInventoryCheckBox"
                                                              Content="Inventory CSV"
                                                              Checked="SettingsEmailOptionChanged"
                                                              Unchecked="SettingsEmailOptionChanged"/>
                                                    <CheckBox x:Name="SettingsEmailSalesDetailCheckBox"
                                                              Content="Sales detail CSV"
                                                              Checked="SettingsEmailOptionChanged"
                                                              Unchecked="SettingsEmailOptionChanged"/>
                                                    <CheckBox x:Name="SettingsEmailCorrectionsCheckBox"
                                                              Content="Corrections CSV"
                                                              Checked="SettingsEmailOptionChanged"
                                                              Unchecked="SettingsEmailOptionChanged"/>
                                                    <CheckBox x:Name="SettingsEmailAnomaliesCheckBox"
                                                              Content="Anomalies CSV"
                                                              Checked="SettingsEmailOptionChanged"
                                                              Unchecked="SettingsEmailOptionChanged"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            Spacing="4">
                                                    <CheckBox x:Name="SettingsEmailPlacementEventsCheckBox"
                                                              Content="Placement events CSV"
                                                              Checked="SettingsEmailOptionChanged"
                                                              Unchecked="SettingsEmailOptionChanged"/>
                                                    <CheckBox x:Name="SettingsEmailBinAssignmentsCheckBox"
                                                              Content="Bin assignments CSV"
                                                              Checked="SettingsEmailOptionChanged"
                                                              Unchecked="SettingsEmailOptionChanged"/>
                                                    <CheckBox x:Name="SettingsEmailInitializationCheckBox"
                                                              Content="Initialization CSV"
                                                              Checked="SettingsEmailOptionChanged"
                                                              Unchecked="SettingsEmailOptionChanged"/>
                                                    <CheckBox x:Name="SettingsEmailAuditCheckBox"
                                                              Content="Closing audit CSV"
                                                              Checked="SettingsEmailOptionChanged"
                                                              Unchecked="SettingsEmailOptionChanged"/>
                                                    <CheckBox x:Name="SettingsEmailPdfCheckBox"
                                                              Content="PDF closing report"
                                                              Checked="SettingsEmailOptionChanged"
                                                              Unchecked="SettingsEmailOptionChanged"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock x:Name="SettingsEmailChoicesStatusText"
                                                       Text="Closing email includes all reports."
                                                       Style="{StaticResource SlCaptionTextStyle}"
                                                       TextWrapping="Wrap"/>
                                            <Button Content="Save email settings"
                                                    HorizontalAlignment="Stretch"
                                                    Click="SaveEmailSettingsButton_Click"/>
                                            <TextBlock x:Name="EmailSettingsStatusText"
                                                       Text="Email settings not saved."
                                                       Foreground="{ThemeResource SlTextBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </TabViewItem>
                            </TabView>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{ThemeResource SlSurfaceBrush}"
                BorderBrush="{ThemeResource SlBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock x:Name="StatusText"
                       Text="Ready"
                       Style="{StaticResource SlCaptionTextStyle}"/>
        </Border>

        <Grid x:Name="StartupOverlay"
              Grid.RowSpan="3"
              IsTabStop="True"
              Background="{ThemeResource SlBackgroundBrush}">
            <Border MaxWidth="960"
                    MaxHeight="720"
                    Margin="16"
                    Padding="20"
                    Style="{StaticResource SlPanelBorderStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid RowSpacing="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <Border Width="56"
                                Height="56"
                                CornerRadius="8"
                                Background="{ThemeResource SlAccentBrush}">
                            <Image Source="ms-appx:///Assets/SimpleLottoSplash.png"
                                   Width="56"
                                   Height="56"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="SimpleLotto"
                                       Style="{StaticResource SlPageTitleTextStyle}"/>
                            <TextBlock x:Name="StartupSubtitleText"
                                       Text="First install setup"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <ScrollViewer x:Name="SetupPanel"
                                  Grid.Row="1"
                                  MaxHeight="520"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Required Setup"
                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                            <TextBlock Text="Store identity, state, bins, and Manager login are required before lottery workflows can run."
                                       Style="{StaticResource SlCaptionTextStyle}"
                                       TextWrapping="Wrap"/>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="StoreNameBox"
                                         Header="Store name"
                                         PlaceholderText="Used for license server feedback"/>
                                <ComboBox x:Name="StateComboBox"
                                          Grid.Column="1"
                                          Header="Store state"
                                          HorizontalAlignment="Stretch"
                                          PlaceholderText="Select state"
                                          SelectionChanged="StateComboBox_SelectionChanged"/>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="StoreStreetBox"
                                         Header="Street"
                                         PlaceholderText="Street address"/>
                                <TextBox x:Name="StoreCityBox"
                                         Grid.Column="1"
                                         Header="City"
                                         PlaceholderText="City"/>
                            </Grid>

                            <TextBox x:Name="BarcodeFormatBox"
                                     Header="Barcode format"
                                     IsReadOnly="True"
                                     PlaceholderText="Selected from state"/>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <NumberBox x:Name="BinCountBox"
                                           Header="Number of bins"
                                           Value="90"
                                           Minimum="1"
                                           Maximum="500"
                                           SmallChange="1"
                                           LargeChange="10"
                                           SpinButtonPlacementMode="Inline"/>
                                <TextBlock Grid.Column="1"
                                           Text="Initial import will create this many selectable bins. You can still scan BIN barcodes instead of clicking a bin."
                                           Style="{StaticResource SlCaptionTextStyle}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Bottom"/>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="ManagerPasswordBox"
                                             Header="Manager password"/>
                                <PasswordBox x:Name="ClerkPasswordBox"
                                             Grid.Column="1"
                                             Header="Clerk password (optional)"/>
                            </Grid>

                            <TextBox x:Name="ClerkNameBox"
                                     Header="Clerk name"
                                     PlaceholderText="Optional"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid x:Name="ImportPanel"
                          Grid.Row="1"
                          ColumnSpacing="12"
                          IsTabStop="True"
                          Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Initial Import"
                                           Style="{StaticResource SlSectionTitleTextStyle}"/>
                                <TextBlock x:Name="ImportInstructionText"
                                           Text="Select a bin or scan a bin barcode, then scan a ticket. Bin and ticket scans work in either order."
                                           Style="{StaticResource SlCaptionTextStyle}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Border Grid.Row="1"
                                    Background="{ThemeResource SlSurfaceAltBrush}"
                                    BorderBrush="{ThemeResource SlBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12">
                                <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Scanner ready"
                                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                                        <TextBlock x:Name="ImportScanStatusText"
                                                   Text="Scan BIN barcode and ticket barcode in either order."
                                                   Style="{StaticResource SlCaptionTextStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <GridView x:Name="ImportBinsGridView"
                                      Grid.Row="2"
                                      Height="310"
                                      IsItemClickEnabled="True"
                                      ItemClick="ImportBinsGridView_ItemClick"
                                      SelectionMode="None">
                                <GridView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal"
                                                       MaximumRowsOrColumns="10"/>
                                    </ItemsPanelTemplate>
                                </GridView.ItemsPanel>
                                <GridView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="{StaticResource SlBinTileSize}"
                                                Height="{StaticResource SlBinTileSize}"
                                                Margin="2"
                                                Padding="4,2"
                                                CornerRadius="6"
                                                BorderBrush="{Binding StatusBorderBrush}"
                                                BorderThickness="1"
                                                Background="{Binding StatusBackgroundBrush}">
                                            <StackPanel Spacing="1"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Label}"
                                                           Foreground="{Binding StatusTextBrush}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding StatusText}"
                                                           Foreground="{Binding StatusTextBrush}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    Spacing="12">
                            <Border Background="{ThemeResource SlSurfaceAltBrush}"
                                    BorderBrush="{ThemeResource SlBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="ImportBinCountText"
                                               Text="0 bins ready"
                                               Style="{StaticResource SlSectionTitleTextStyle}"/>
                                    <TextBlock x:Name="ImportPendingText"
                                               Text="No pending scan."
                                               Style="{StaticResource SlCaptionTextStyle}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock x:Name="ImportFailureText"
                                               Text=""
                                               Foreground="{ThemeResource SlDangerBrush}"
                                               TextWrapping="Wrap"/>
                                    <Button x:Name="ResolveImportFailureButton"
                                            Content="Resolve Failure"
                                            HorizontalAlignment="Left"
                                            Visibility="Collapsed"
                                            Click="ResolveImportFailureButton_Click"/>
                                </StackPanel>
                            </Border>

                            <ListView x:Name="ImportListView"
                                      DisplayMemberPath="SummaryText"
                                      Height="300"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="LoginPanel"
                                Grid.Row="1"
                                Spacing="14"
                                Visibility="Collapsed">
                        <TextBlock Text="Login"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                        <TextBlock Text="Enter the password for the selected user."
                                   Style="{StaticResource SlCaptionTextStyle}"/>

                        <ComboBox x:Name="LoginUserComboBox"
                                  Header="User"
                                  HorizontalAlignment="Stretch"/>

                        <PasswordBox x:Name="LoginPasswordBox"
                                     Header="Password"/>
                    </StackPanel>

                    <Grid Grid.Row="2" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="StartupStatusText"
                                   Text="Select the store state and create the Manager password."
                                   Style="{StaticResource SlCaptionTextStyle}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>

                        <Button x:Name="StartupBackButton"
                                Grid.Column="1"
                                Content="Back"
                                Visibility="Collapsed"
                                Click="StartupBackButton_Click"/>

                        <Button x:Name="StartupPrimaryButton"
                                Grid.Column="2"
                                Content="Continue"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="StartupPrimaryButton_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
