<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SimpleLotto.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid"
          SizeChanged="RootGrid_SizeChanged"
          Background="{ThemeResource SlBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{ThemeResource SlSurfaceBrush}"
                BorderBrush="{ThemeResource SlBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,14">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="40"
                        Height="40"
                        CornerRadius="8"
                        Background="{ThemeResource SlAccentBrush}">
                    <Image Source="ms-appx:///Assets/SimpleLottoLogo64.png"
                           Width="40"
                           Height="40"
                           Stretch="UniformToFill"/>
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="2">
                    <TextBlock Text="SimpleLotto"
                               Style="{StaticResource SlPageTitleTextStyle}"/>
                    <TextBlock Text="Counter sales and shift totals"
                               Style="{StaticResource SlCaptionTextStyle}"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Close Shift"
                        MinWidth="108"
                        Click="CloseShiftButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="NavColumn" Width="190"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{ThemeResource SlSurfaceBrush}"
                    BorderBrush="{ThemeResource SlBorderBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="12">
                <StackPanel Spacing="8">
                    <Grid>
                        <Button x:Name="NavToggleButton"
                                Content="&lt;-"
                                Width="42"
                                Height="32"
                                HorizontalAlignment="Right"
                                Click="NavToggleButton_Click"/>
                    </Grid>

                    <Button Tag="Dashboard"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Dashboard">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE80F;" FontSize="16"/>
                            <TextBlock x:Name="DashboardNavLabel" Text="Dashboard" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Bins"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Bins">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xECA5;" FontSize="16"/>
                            <TextBlock x:Name="BinsNavLabel" Text="Bins"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Inventory"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Inventory">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE7B8;" FontSize="16"/>
                            <TextBlock x:Name="InventoryNavLabel" Text="Inventory"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Closing"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Closing">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE9D5;" FontSize="16"/>
                            <TextBlock x:Name="ClosingNavLabel" Text="Closing"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Settings"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Settings">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE713;" FontSize="16"/>
                            <TextBlock x:Name="SettingsNavLabel" Text="Settings"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Grid x:Name="DashboardContent"
                  Grid.Column="1"
                  Padding="16"
                  ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource SlPanelBorderStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Scanner"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                        <TextBlock Text="Ready"
                                   Style="{StaticResource SlCaptionTextStyle}"/>
                    </StackPanel>

                    <Border Background="{ThemeResource SlSurfaceAltBrush}"
                            BorderBrush="{ThemeResource SlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="DashboardScannerModeText"
                                       Text="Global scanner"
                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                            <TextBlock x:Name="DashboardScannerStatusText"
                                       Text="Ready for scanner input."
                                       Style="{StaticResource SlCaptionTextStyle}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="DashboardLastScanText"
                                       Text="No scan captured this shift."
                                       Foreground="{ThemeResource SlTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource SlSurfaceAltBrush}"
                            BorderBrush="{ThemeResource SlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Pairing"
                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                            <TextBlock x:Name="DashboardPairingStatusText"
                                       Text="Background capture: not paired"
                                       Style="{StaticResource SlCaptionTextStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource SlPanelBorderStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Sales"
                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                            <TextBlock x:Name="SalesSubtitleText"
                                       Text="No entries yet"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Void Selected"
                                MinWidth="116"
                                Click="VoidSelectedButton_Click"/>
                    </Grid>

                    <Grid Grid.Row="1"
                          Padding="12,8"
                          Background="{ThemeResource SlSurfaceAltBrush}"
                          ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="96"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Time" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="1" Text="Game / Bin" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="2" Text="Tickets" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="3" Text="Amount" Style="{StaticResource SlCaptionTextStyle}"/>
                    </Grid>

                    <ListView x:Name="SalesListView"
                              Grid.Row="2"
                              SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="44"
                                      Padding="12,8"
                                      ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="96"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding TimeText}"
                                               Foreground="{ThemeResource SlMutedTextBrush}"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1"
                                                Spacing="1"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding GameText}"
                                                   Foreground="{ThemeResource SlTextBrush}"/>
                                        <TextBlock Text="{Binding DetailText}"
                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Quantity}"
                                               Foreground="{ThemeResource SlTextBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding AmountText}"
                                               Foreground="{ThemeResource SlTextBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2"
                        Spacing="16">
                <Border Style="{StaticResource SlPanelBorderStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Current Shift"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>

                        <StackPanel Spacing="2">
                            <TextBlock x:Name="RevenueText"
                                       Text="$0.00"
                                       Style="{StaticResource SlMetricTextStyle}"/>
                            <TextBlock Text="Sales amount"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock x:Name="TicketsText"
                                       Text="0"
                                       Style="{StaticResource SlMetricTextStyle}"/>
                            <TextBlock Text="Tickets sold"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock x:Name="AverageText"
                                       Text="$0.00"
                                       Style="{StaticResource SlMetricTextStyle}"/>
                            <TextBlock Text="Average ticket"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SlPanelBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Game Summary"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                        <TextBlock x:Name="GameMixText"
                                   Text="No sales recorded."
                                   Foreground="{ThemeResource SlMutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            </Grid>

            <Grid x:Name="SectionContent"
                  Grid.Column="1"
                  Padding="16"
                  Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid x:Name="BinsContent"
                              RowSpacing="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Bins"
                                               Style="{StaticResource SlSectionTitleTextStyle}"/>
                                    <TextBlock Text="Active and dormant bundle display state. Placement scans assign unplaced bundles; moves are manual from a bin."
                                               Style="{StaticResource SlCaptionTextStyle}"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Style="{StaticResource SlPanelBorderStyle}">
                                    <StackPanel Spacing="2">
                                        <TextBlock x:Name="BinsTotalText"
                                                   Text="0"
                                                   Style="{StaticResource SlMetricTextStyle}"/>
                                        <TextBlock Text="Total bins"
                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2"
                                        Style="{StaticResource SlPanelBorderStyle}">
                                    <StackPanel Spacing="2">
                                        <TextBlock x:Name="BinsActiveText"
                                                   Text="0"
                                                   Style="{StaticResource SlMetricTextStyle}"/>
                                        <TextBlock Text="Active bins"
                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3"
                                        Style="{StaticResource SlPanelBorderStyle}">
                                    <StackPanel Spacing="2">
                                        <TextBlock x:Name="BinsBundleText"
                                                   Text="0"
                                                   Style="{StaticResource SlMetricTextStyle}"/>
                                        <TextBlock Text="Bundles"
                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid Grid.Row="1"
                                  ColumnSpacing="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="BinLayoutColumn" Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition x:Name="BinDetailColumn" Width="320"/>
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource SlPanelBorderStyle}">
                                    <Grid RowSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Working Bin Layout"
                                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                                        <StackPanel Grid.Row="1"
                                                    Orientation="Horizontal"
                                                    Spacing="12">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="3"
                                                        Background="{ThemeResource SlBinLowBrush}"/>
                                                <TextBlock Text="Low"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="3"
                                                        Background="{ThemeResource SlBinMediumBrush}"/>
                                                <TextBlock Text="Medium"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="3"
                                                        Background="{ThemeResource SlBinHighBrush}"/>
                                                <TextBlock Text="High"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="3"
                                                        Background="{ThemeResource SlBinHighStackedBrush}"/>
                                                <TextBlock Text="Multiple = darker shade"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="6">
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="3"
                                                        BorderBrush="{ThemeResource SlBorderBrush}"
                                                        BorderThickness="1"
                                                        Background="{ThemeResource SlBinEmptyBrush}"/>
                                                <TextBlock Text="Empty"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <GridView x:Name="BinsGridView"
                                                  Grid.Row="2"
                                                  MinHeight="360"
                                                  IsItemClickEnabled="True"
                                                  ItemClick="BinsGridView_ItemClick"
                                                  SelectionMode="None">
                                            <GridView.ItemContainerStyle>
                                                <Style TargetType="GridViewItem">
                                                    <Setter Property="MinWidth" Value="{StaticResource SlBinTileSize}"/>
                                                    <Setter Property="MinHeight" Value="{StaticResource SlBinTileSize}"/>
                                                    <Setter Property="Margin" Value="4"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                </Style>
                                            </GridView.ItemContainerStyle>
                                            <GridView.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsWrapGrid Orientation="Horizontal"
                                                                   MaximumRowsOrColumns="10"/>
                                                </ItemsPanelTemplate>
                                            </GridView.ItemsPanel>
                                            <GridView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="{StaticResource SlBinTileSize}"
                                                            Height="{StaticResource SlBinTileSize}"
                                                            Padding="4,2"
                                                            CornerRadius="6"
                                                            BorderBrush="{Binding BorderBrush}"
                                                            BorderThickness="1"
                                                            Background="{Binding BackgroundBrush}"
                                                            Tapped="BinTile_Tapped">
                                                        <StackPanel Spacing="0"
                                                                    HorizontalAlignment="Stretch"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding BinText}"
                                                                       Foreground="{Binding ForegroundBrush}"
                                                                       FontSize="16"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Stretch"
                                                                       TextAlignment="Center"/>
                                                            <TextBlock Text="{Binding GameTextShort}"
                                                                       Foreground="{Binding ForegroundBrush}"
                                                                       FontSize="12"
                                                                       HorizontalAlignment="Stretch"
                                                                       TextAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxLines="1"
                                                                       Visibility="{Binding GameTextVisibility}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </GridView.ItemTemplate>
                                        </GridView>
                                    </Grid>
                                </Border>

                                <Thumb Grid.Column="1"
                                       Width="8"
                                       DragDelta="BinDetailSplitter_DragDelta">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Grid Background="Transparent">
                                                <Border Width="2"
                                                        HorizontalAlignment="Center"
                                                        Background="{ThemeResource SlBorderBrush}"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>

                                <Border Grid.Column="2"
                                        Style="{StaticResource SlPanelBorderStyle}">
                                    <Grid RowSpacing="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock x:Name="BinDetailText"
                                                   Text="Bin Details (0 bundles)"
                                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                                        <ListView x:Name="BinBundlesListView"
                                                  Grid.Row="1"
                                                  MaxHeight="340"
                                                  Padding="0"
                                                  VerticalAlignment="Top"
                                                  SelectionMode="None">
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0,0,0,8"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="VerticalContentAlignment" Value="Top"/>
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="10,8"
                                                            CornerRadius="6"
                                                            BorderThickness="1"
                                                            BorderBrush="{Binding CardBorderBrush}"
                                                            Background="{Binding CardBackgroundBrush}">
                                                        <Grid RowSpacing="4"
                                                              ColumnSpacing="8">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{Binding StatusText}"
                                                                       Foreground="{Binding CardForegroundBrush}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="12"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding TicketText}"
                                                                       Foreground="{Binding CardForegroundBrush}"
                                                                       FontSize="12"/>
                                                            <TextBlock Grid.Row="1"
                                                                       Text="{Binding GameIdText}"
                                                                       Foreground="{Binding CardForegroundBrush}"
                                                                       TextWrapping="WrapWholeWords"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxLines="1"/>
                                                            <TextBlock Grid.Row="1"
                                                                       Grid.Column="1"
                                                                       Text="{Binding BundleText}"
                                                                       Foreground="{Binding CardForegroundBrush}"
                                                                       FontSize="12"/>
                                                            <TextBlock Grid.Row="2"
                                                                       Text="{Binding GameNameText}"
                                                                       Foreground="{Binding CardForegroundBrush}"
                                                                       TextWrapping="WrapWholeWords"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxLines="2"/>
                                                            <TextBlock Grid.Row="2"
                                                                       Grid.Column="1"
                                                                       Text="{Binding BinText}"
                                                                       Foreground="{Binding CardForegroundBrush}"
                                                                       FontSize="12"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid x:Name="InventoryContent"
                              RowSpacing="16"
                              Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Inventory"
                                               Style="{StaticResource SlSectionTitleTextStyle}"/>
                                    <TextBlock Text="Receiving is unopened stock intake. Initial import and activation are active bin placement records."
                                               Style="{StaticResource SlCaptionTextStyle}"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Style="{StaticResource SlPanelBorderStyle}">
                                    <StackPanel Spacing="2">
                                        <TextBlock x:Name="InventoryBundleCountText"
                                                   Text="0"
                                                   Style="{StaticResource SlMetricTextStyle}"/>
                                        <TextBlock Text="Active bin bundles"
                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TabView x:Name="InventoryTabs"
                                     Grid.Row="1"
                                     IsAddTabButtonVisible="False"
                                     CanDragTabs="False">
                                <TabViewItem x:Name="ReceivingTab"
                                             Header="Receiving"
                                             IsClosable="False">
                                    <Grid Padding="0,16,0,0"
                                          ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="280"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource SlPanelBorderStyle}">
                                            <Grid RowSpacing="12">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <Grid ColumnSpacing="12"
                                                      RowSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="220"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="Inventory Receiving"
                                                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                                                        <TextBlock x:Name="ReceivingCountText"
                                                                   Text="0 received bundles"
                                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                                    </StackPanel>
                                                    <TextBox x:Name="ReceivingSearchBox"
                                                             Grid.Column="1"
                                                             Header="Search Receiving"
                                                             PlaceholderText="Game, bundle, or ticket"
                                                             TextChanged="ReceivingSearchBox_TextChanged"/>
                                                    <Button x:Name="ReceivingPreviousPageButton"
                                                            Grid.Column="2"
                                                            Content="Previous"
                                                            MinWidth="88"
                                                            VerticalAlignment="Bottom"
                                                            Click="ReceivingPreviousPageButton_Click"/>
                                                    <Button x:Name="ReceivingNextPageButton"
                                                            Grid.Column="3"
                                                            Content="Next"
                                                            MinWidth="72"
                                                            VerticalAlignment="Bottom"
                                                            Click="ReceivingNextPageButton_Click"/>
                                                </Grid>
                                                <Grid Grid.Row="1"
                                                      Padding="12,8"
                                                      Background="{ThemeResource SlSurfaceAltBrush}"
                                                      ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="110"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Received" Style="{StaticResource SlCaptionTextStyle}"/>
                                                    <TextBlock Grid.Column="1" Text="Game / Bundle" Style="{StaticResource SlCaptionTextStyle}"/>
                                                    <TextBlock Grid.Column="2" Text="Ticket" Style="{StaticResource SlCaptionTextStyle}"/>
                                                </Grid>
                                                <TextBlock x:Name="ReceivingPageStatusText"
                                                           Grid.Row="2"
                                                           Text="Page 1 of 1"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                                <ListView x:Name="ReceivingListView"
                                                          Grid.Row="3"
                                                          MinHeight="220"
                                                          SelectionMode="None"
                                                          SizeChanged="InventoryPagedList_SizeChanged">
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid MinHeight="44"
                                                                  Padding="12,8"
                                                                  ColumnSpacing="12">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="110"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="110"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Source}"
                                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                                                <StackPanel Grid.Column="1"
                                                                            Spacing="1">
                                                                    <TextBlock Text="{Binding GameText}"
                                                                               Foreground="{ThemeResource SlTextBrush}"/>
                                                                    <TextBlock Text="{Binding BundleText}"
                                                                               Style="{StaticResource SlCaptionTextStyle}"/>
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding Ticket}"
                                                                           Foreground="{ThemeResource SlTextBrush}"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Column="1"
                                                Style="{StaticResource SlPanelBorderStyle}">
                                            <StackPanel Spacing="12">
                                                <TextBlock Text="Receiving Rules"
                                                           Style="{StaticResource SlSectionTitleTextStyle}"/>
                                                <TextBlock Text="Unopened receiving expects ticket 000."
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
