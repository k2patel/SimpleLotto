<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SimpleLotto.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{ThemeResource SlBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{ThemeResource SlSurfaceBrush}"
                BorderBrush="{ThemeResource SlBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="40"
                        Height="40"
                        CornerRadius="8"
                        Background="{ThemeResource SlAccentBrush}">
                    <Image Source="ms-appx:///Assets/SimpleLottoLogo64.png"
                           Width="40"
                           Height="40"
                           Stretch="UniformToFill"/>
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="2">
                    <TextBlock Text="SimpleLotto"
                               Style="{StaticResource SlPageTitleTextStyle}"/>
                    <TextBlock Text="Counter sales and shift totals"
                               Style="{StaticResource SlCaptionTextStyle}"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Close Shift"
                        MinWidth="108"
                        Click="CloseShiftButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavColumn" Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{ThemeResource SlSurfaceBrush}"
                    BorderBrush="{ThemeResource SlBorderBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="12">
                <StackPanel Spacing="8">
                    <Button x:Name="NavToggleButton"
                            Content="Menu"
                            HorizontalAlignment="Stretch"
                            Click="NavToggleButton_Click"/>

                    <Button Tag="Dashboard"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Dashboard">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE80F;" FontSize="16"/>
                            <TextBlock x:Name="DashboardNavLabel" Text="Dashboard" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Bins"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Bins">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xECA5;" FontSize="16"/>
                            <TextBlock x:Name="BinsNavLabel" Text="Bins"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Inventory"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Inventory">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE7B8;" FontSize="16"/>
                            <TextBlock x:Name="InventoryNavLabel" Text="Inventory"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Closing"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Closing">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE9D5;" FontSize="16"/>
                            <TextBlock x:Name="ClosingNavLabel" Text="Closing"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Settings"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Settings">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE713;" FontSize="16"/>
                            <TextBlock x:Name="SettingsNavLabel" Text="Settings"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Grid x:Name="DashboardContent"
                  Grid.Column="1"
                  Padding="24"
                  ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource SlPanelBorderStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="2">
                        <TextBlock Text="New Sale"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                        <TextBlock Text="Record a lottery ticket sale for the current shift."
                                   Style="{StaticResource SlCaptionTextStyle}"/>
                    </StackPanel>

                    <TextBox x:Name="GameIdTextBox"
                             Header="Game ID"
                             PlaceholderText="Scan or enter game ID"/>

                    <TextBox x:Name="BinTextBox"
                             Header="Bin"
                             PlaceholderText="Scan or enter bin number"/>

                    <TextBox x:Name="TicketTextBox"
                             Header="Ticket"
                             PlaceholderText="Scan or enter ticket number"/>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <NumberBox x:Name="QuantityBox"
                                   Header="Ticket count"
                                   Value="1"
                                   Minimum="1"
                                   Maximum="999"
                                   SmallChange="1"
                                   LargeChange="5"
                                   SpinButtonPlacementMode="Inline"/>

                        <NumberBox x:Name="PriceBox"
                                   Grid.Column="1"
                                   Header="Amount"
                                   Value="0"
                                   Minimum="0"
                                   Maximum="999"
                                   SmallChange="1"
                                   LargeChange="5"
                                   SpinButtonPlacementMode="Inline"/>
                    </Grid>

                    <Button x:Name="AddSaleButton"
                            Content="Add Sale"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Click="AddSaleButton_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource SlPanelBorderStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Sales"
                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                            <TextBlock x:Name="SalesSubtitleText"
                                       Text="No entries yet"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Void Selected"
                                MinWidth="116"
                                Click="VoidSelectedButton_Click"/>
                    </Grid>

                    <Grid Grid.Row="1"
                          Padding="12,8"
                          Background="{ThemeResource SlSurfaceAltBrush}"
                          ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="96"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Time" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="1" Text="Game / Bin" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="2" Text="Tickets" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="3" Text="Amount" Style="{StaticResource SlCaptionTextStyle}"/>
                    </Grid>

                    <ListView x:Name="SalesListView"
                              Grid.Row="2"
                              SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="44"
                                      Padding="12,8"
                                      ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="96"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding TimeText}"
                                               Foreground="{ThemeResource SlMutedTextBrush}"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1"
                                                Spacing="1"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding GameText}"
                                                   Foreground="{ThemeResource SlTextBrush}"/>
                                        <TextBlock Text="{Binding DetailText}"
                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Quantity}"
                                               Foreground="{ThemeResource SlTextBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding AmountText}"
                                               Foreground="{ThemeResource SlTextBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2"
                        Spacing="16">
                <Border Style="{StaticResource SlPanelBorderStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Current Shift"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>

                        <StackPanel Spacing="2">
                            <TextBlock x:Name="RevenueText"
                                       Text="$0.00"
                                       Style="{StaticResource SlMetricTextStyle}"/>
                            <TextBlock Text="Sales amount"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock x:Name="TicketsText"
                                       Text="0"
                                       Style="{StaticResource SlMetricTextStyle}"/>
                            <TextBlock Text="Tickets sold"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock x:Name="AverageText"
                                       Text="$0.00"
                                       Style="{StaticResource SlMetricTextStyle}"/>
                            <TextBlock Text="Average ticket"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SlPanelBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Game Summary"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                        <TextBlock x:Name="GameMixText"
                                   Text="No sales recorded."
                                   Foreground="{ThemeResource SlMutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            </Grid>

            <Grid x:Name="SectionContent"
                  Grid.Column="1"
                  Padding="24"
                  Visibility="Collapsed">
                <Border Style="{StaticResource SlPanelBorderStyle}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="SectionTitleText"
                                   Text="Bins"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                        <TextBlock x:Name="SectionDescriptionText"
                                   Text="This section will use the same operational model defined in the product instructions."
                                   Style="{StaticResource SlCaptionTextStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{ThemeResource SlSurfaceBrush}"
                BorderBrush="{ThemeResource SlBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <TextBlock x:Name="StatusText"
                       Text="Ready"
                       Style="{StaticResource SlCaptionTextStyle}"/>
        </Border>

        <Grid x:Name="StartupOverlay"
              Grid.RowSpan="3"
              Background="{ThemeResource SlBackgroundBrush}">
            <Border Width="1060"
                    MaxHeight="720"
                    Padding="28"
                    Style="{StaticResource SlPanelBorderStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid RowSpacing="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <Border Width="56"
                                Height="56"
                                CornerRadius="8"
                                Background="{ThemeResource SlAccentBrush}">
                            <Image Source="ms-appx:///Assets/SimpleLottoSplash.png"
                                   Width="56"
                                   Height="56"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="SimpleLotto"
                                       Style="{StaticResource SlPageTitleTextStyle}"/>
                            <TextBlock x:Name="StartupSubtitleText"
                                       Text="First install setup"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <ScrollViewer x:Name="SetupPanel"
                                  Grid.Row="1"
                                  MaxHeight="520"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Required Setup"
                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                            <TextBlock Text="Store identity, state, bins, and Manager login are required before lottery workflows can run."
                                       Style="{StaticResource SlCaptionTextStyle}"
                                       TextWrapping="Wrap"/>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="StoreNameBox"
                                         Header="Store name"
                                         PlaceholderText="Used for license server feedback"/>
                                <ComboBox x:Name="StateComboBox"
                                          Grid.Column="1"
                                          Header="Store state"
                                          HorizontalAlignment="Stretch"
                                          PlaceholderText="Select state"/>
                            </Grid>

                            <TextBox x:Name="StoreAddressBox"
                                     Header="Store address"
                                     PlaceholderText="Street, city, ZIP"/>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <NumberBox x:Name="BinCountBox"
                                           Header="Number of bins"
                                           Value="90"
                                           Minimum="1"
                                           Maximum="500"
                                           SmallChange="1"
                                           LargeChange="10"
                                           SpinButtonPlacementMode="Inline"/>
                                <TextBlock Grid.Column="1"
                                           Text="Initial import will create this many selectable bins. You can still scan BIN barcodes instead of clicking a bin."
                                           Style="{StaticResource SlCaptionTextStyle}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Bottom"/>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="ManagerPasswordBox"
                                             Header="Manager password"/>
                                <PasswordBox x:Name="ClerkPasswordBox"
                                             Grid.Column="1"
                                             Header="Clerk password (optional)"/>
                            </Grid>

                            <TextBox x:Name="ClerkNameBox"
                                     Header="Clerk name"
                                     PlaceholderText="Optional"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid x:Name="ImportPanel"
                          Grid.Row="1"
                          ColumnSpacing="18"
                          Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="340"/>
                        </Grid.ColumnDefinitions>

                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Initial Import"
                                           Style="{StaticResource SlSectionTitleTextStyle}"/>
                                <TextBlock x:Name="ImportInstructionText"
                                           Text="Select a bin, scan a bin barcode, or scan a ticket. Once SimpleLotto has one bin and one ticket, the import is recorded."
                                           Style="{StaticResource SlCaptionTextStyle}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Grid Grid.Row="1"
                                  ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="ImportScanBox"
                                         Header="Scanner input"
                                         PlaceholderText="Scan BIN-12 or a ticket barcode"
                                         KeyDown="ImportScanBox_KeyDown"/>
                                <Button Grid.Column="1"
                                        Content="Process Scan"
                                        MinWidth="120"
                                        VerticalAlignment="Bottom"
                                        Click="ProcessImportScanButton_Click"/>
                            </Grid>

                            <GridView x:Name="ImportBinsGridView"
                                      Grid.Row="2"
                                      Height="310"
                                      IsItemClickEnabled="True"
                                      ItemClick="ImportBinsGridView_ItemClick"
                                      SelectionMode="None">
                                <GridView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <ItemsWrapGrid Orientation="Horizontal"
                                                       MaximumRowsOrColumns="8"/>
                                    </ItemsPanelTemplate>
                                </GridView.ItemsPanel>
                                <GridView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="70"
                                                Height="54"
                                                Margin="3"
                                                Padding="6"
                                                CornerRadius="6"
                                                BorderBrush="{Binding StatusBorderBrush}"
                                                BorderThickness="2"
                                                Background="{Binding StatusBackgroundBrush}">
                                            <StackPanel Spacing="1"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Label}"
                                                           Foreground="{Binding StatusTextBrush}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding StatusText}"
                                                           Foreground="{Binding StatusTextBrush}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    Spacing="12">
                            <Border Background="{ThemeResource SlSurfaceAltBrush}"
                                    BorderBrush="{ThemeResource SlBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock x:Name="ImportBinCountText"
                                               Text="0 bins ready"
                                               Style="{StaticResource SlSectionTitleTextStyle}"/>
                                    <TextBlock x:Name="ImportPendingText"
                                               Text="No pending scan."
                                               Style="{StaticResource SlCaptionTextStyle}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock x:Name="ImportFailureText"
                                               Text=""
                                               Foreground="{ThemeResource SlDangerBrush}"
                                               TextWrapping="Wrap"/>
                                    <Button x:Name="ResolveImportFailureButton"
                                            Content="Resolve Failure"
                                            HorizontalAlignment="Left"
                                            Visibility="Collapsed"
                                            Click="ResolveImportFailureButton_Click"/>
                                </StackPanel>
                            </Border>

                            <ListView x:Name="ImportListView"
                                      DisplayMemberPath="SummaryText"
                                      Height="300"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="LoginPanel"
                                Grid.Row="1"
                                Spacing="14"
                                Visibility="Collapsed">
                        <TextBlock Text="Login"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                        <TextBlock Text="Login starts the active shift for the selected user."
                                   Style="{StaticResource SlCaptionTextStyle}"/>

                        <ComboBox x:Name="LoginUserComboBox"
                                  Header="User"
                                  HorizontalAlignment="Stretch"/>

                        <PasswordBox x:Name="LoginPasswordBox"
                                     Header="Password"/>
                    </StackPanel>

                    <Grid Grid.Row="2" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="StartupStatusText"
                                   Text="Select the store state and create the Manager password."
                                   Style="{StaticResource SlCaptionTextStyle}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>

                        <Button x:Name="StartupBackButton"
                                Grid.Column="1"
                                Content="Back"
                                Visibility="Collapsed"
                                Click="StartupBackButton_Click"/>

                        <Button x:Name="StartupPrimaryButton"
                                Grid.Column="2"
                                Content="Continue"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="StartupPrimaryButton_Click"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
