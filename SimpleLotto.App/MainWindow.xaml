<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SimpleLotto.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{ThemeResource SlBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{ThemeResource SlSurfaceBrush}"
                BorderBrush="{ThemeResource SlBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="40"
                        Height="40"
                        CornerRadius="8"
                        Background="{ThemeResource SlAccentBrush}">
                    <TextBlock Text="SL"
                               Foreground="{ThemeResource SlAccentTextBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="2">
                    <TextBlock Text="SimpleLotto"
                               Style="{StaticResource SlPageTitleTextStyle}"/>
                    <TextBlock Text="Counter sales and daily totals"
                               Style="{StaticResource SlCaptionTextStyle}"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Reset Day"
                        MinWidth="108"
                        Click="ResetDayButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Padding="24"
              ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource SlPanelBorderStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="2">
                        <TextBlock Text="New Sale"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                        <TextBlock Text="Add a ticket sale to the current day."
                                   Style="{StaticResource SlCaptionTextStyle}"/>
                    </StackPanel>

                    <ComboBox x:Name="GameComboBox"
                              Header="Game"
                              HorizontalAlignment="Stretch"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Powerball"/>
                        <ComboBoxItem Content="Mega Millions"/>
                        <ComboBoxItem Content="Pick 3"/>
                        <ComboBoxItem Content="Pick 4"/>
                        <ComboBoxItem Content="Scratch Off"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>

                    <TextBox x:Name="TicketTextBox"
                             Header="Ticket or note"
                             PlaceholderText="Optional"/>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <NumberBox x:Name="QuantityBox"
                                   Header="Qty"
                                   Value="1"
                                   Minimum="1"
                                   Maximum="999"
                                   SmallChange="1"
                                   LargeChange="5"
                                   SpinButtonPlacementMode="Inline"/>

                        <NumberBox x:Name="PriceBox"
                                   Grid.Column="1"
                                   Header="Unit price"
                                   Value="2"
                                   Minimum="0"
                                   Maximum="999"
                                   SmallChange="1"
                                   LargeChange="5"
                                   SpinButtonPlacementMode="Inline"/>
                    </Grid>

                    <Button x:Name="AddSaleButton"
                            Content="Add Sale"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Click="AddSaleButton_Click"/>

                    <TextBlock Text="Quick picks"
                               Style="{StaticResource SlCaptionTextStyle}"
                               Margin="0,6,0,0"/>
                    <Grid ColumnSpacing="8" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Button Content="Powerball $2"
                                Tag="Powerball|2"
                                Click="QuickPickButton_Click"/>
                        <Button Grid.Column="1"
                                Content="Mega $2"
                                Tag="Mega Millions|2"
                                Click="QuickPickButton_Click"/>
                        <Button Grid.Row="1"
                                Content="Pick 3 $1"
                                Tag="Pick 3|1"
                                Click="QuickPickButton_Click"/>
                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Content="Scratch $5"
                                Tag="Scratch Off|5"
                                Click="QuickPickButton_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource SlPanelBorderStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Sales"
                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                            <TextBlock x:Name="SalesSubtitleText"
                                       Text="No entries yet"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Void Selected"
                                MinWidth="116"
                                Click="VoidSelectedButton_Click"/>
                    </Grid>

                    <Grid Grid.Row="1"
                          Padding="12,8"
                          Background="{ThemeResource SlSurfaceAltBrush}"
                          ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="96"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Time" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="1" Text="Game" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="2" Text="Qty" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="3" Text="Amount" Style="{StaticResource SlCaptionTextStyle}"/>
                    </Grid>

                    <ListView x:Name="SalesListView"
                              Grid.Row="2"
                              SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="44"
                                      Padding="12,8"
                                      ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="96"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding TimeText}"
                                               Foreground="{ThemeResource SlMutedTextBrush}"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1"
                                                Spacing="1"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Game}"
                                                   Foreground="{ThemeResource SlTextBrush}"/>
                                        <TextBlock Text="{Binding Ticket}"
                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Quantity}"
                                               Foreground="{ThemeResource SlTextBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding AmountText}"
                                               Foreground="{ThemeResource SlTextBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2"
                        Spacing="16">
                <Border Style="{StaticResource SlPanelBorderStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Today"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>

                        <StackPanel Spacing="2">
                            <TextBlock x:Name="RevenueText"
                                       Text="$0.00"
                                       Style="{StaticResource SlMetricTextStyle}"/>
                            <TextBlock Text="Sales amount"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock x:Name="TicketsText"
                                       Text="0"
                                       Style="{StaticResource SlMetricTextStyle}"/>
                            <TextBlock Text="Tickets sold"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock x:Name="AverageText"
                                       Text="$0.00"
                                       Style="{StaticResource SlMetricTextStyle}"/>
                            <TextBlock Text="Average ticket"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SlPanelBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Game Mix"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                        <TextBlock x:Name="GameMixText"
                                   Text="No sales recorded."
                                   Foreground="{ThemeResource SlMutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="{ThemeResource SlSurfaceBrush}"
                BorderBrush="{ThemeResource SlBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <TextBlock x:Name="StatusText"
                       Text="Ready"
                       Style="{StaticResource SlCaptionTextStyle}"/>
        </Border>
    </Grid>
</Window>
