<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SimpleLotto.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{ThemeResource SlBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{ThemeResource SlSurfaceBrush}"
                BorderBrush="{ThemeResource SlBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="40"
                        Height="40"
                        CornerRadius="8"
                        Background="{ThemeResource SlAccentBrush}">
                    <TextBlock Text="SL"
                               Foreground="{ThemeResource SlAccentTextBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="2">
                    <TextBlock Text="SimpleLotto"
                               Style="{StaticResource SlPageTitleTextStyle}"/>
                    <TextBlock Text="Counter sales and shift totals"
                               Style="{StaticResource SlCaptionTextStyle}"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Close Shift"
                        MinWidth="108"
                        Click="CloseShiftButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavColumn" Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{ThemeResource SlSurfaceBrush}"
                    BorderBrush="{ThemeResource SlBorderBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="12">
                <StackPanel Spacing="8">
                    <Button x:Name="NavToggleButton"
                            Content="Menu"
                            HorizontalAlignment="Stretch"
                            Click="NavToggleButton_Click"/>

                    <Button Tag="Dashboard"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Dashboard">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE80F;" FontSize="16"/>
                            <TextBlock x:Name="DashboardNavLabel" Text="Dashboard" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Bins"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Bins">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xECA5;" FontSize="16"/>
                            <TextBlock x:Name="BinsNavLabel" Text="Bins"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Inventory"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Inventory">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE7B8;" FontSize="16"/>
                            <TextBlock x:Name="InventoryNavLabel" Text="Inventory"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Closing"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Closing">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE9D5;" FontSize="16"/>
                            <TextBlock x:Name="ClosingNavLabel" Text="Closing"/>
                        </StackPanel>
                    </Button>
                    <Button Tag="Settings"
                            HorizontalAlignment="Stretch"
                            Click="NavButton_Click"
                            ToolTipService.ToolTip="Settings">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE713;" FontSize="16"/>
                            <TextBlock x:Name="SettingsNavLabel" Text="Settings"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Grid x:Name="DashboardContent"
                  Grid.Column="1"
                  Padding="24"
                  ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource SlPanelBorderStyle}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="2">
                        <TextBlock Text="New Sale"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                        <TextBlock Text="Record a lottery ticket sale for the current shift."
                                   Style="{StaticResource SlCaptionTextStyle}"/>
                    </StackPanel>

                    <TextBox x:Name="GameIdTextBox"
                             Header="Game ID"
                             PlaceholderText="Scan or enter game ID"/>

                    <TextBox x:Name="BinTextBox"
                             Header="Bin"
                             PlaceholderText="Scan or enter bin number"/>

                    <TextBox x:Name="TicketTextBox"
                             Header="Ticket"
                             PlaceholderText="Scan or enter ticket number"/>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <NumberBox x:Name="QuantityBox"
                                   Header="Ticket count"
                                   Value="1"
                                   Minimum="1"
                                   Maximum="999"
                                   SmallChange="1"
                                   LargeChange="5"
                                   SpinButtonPlacementMode="Inline"/>

                        <NumberBox x:Name="PriceBox"
                                   Grid.Column="1"
                                   Header="Amount"
                                   Value="0"
                                   Minimum="0"
                                   Maximum="999"
                                   SmallChange="1"
                                   LargeChange="5"
                                   SpinButtonPlacementMode="Inline"/>
                    </Grid>

                    <Button x:Name="AddSaleButton"
                            Content="Add Sale"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Click="AddSaleButton_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource SlPanelBorderStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Sales"
                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                            <TextBlock x:Name="SalesSubtitleText"
                                       Text="No entries yet"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Void Selected"
                                MinWidth="116"
                                Click="VoidSelectedButton_Click"/>
                    </Grid>

                    <Grid Grid.Row="1"
                          Padding="12,8"
                          Background="{ThemeResource SlSurfaceAltBrush}"
                          ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="96"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Time" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="1" Text="Game / Bin" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="2" Text="Tickets" Style="{StaticResource SlCaptionTextStyle}"/>
                        <TextBlock Grid.Column="3" Text="Amount" Style="{StaticResource SlCaptionTextStyle}"/>
                    </Grid>

                    <ListView x:Name="SalesListView"
                              Grid.Row="2"
                              SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="44"
                                      Padding="12,8"
                                      ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="96"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding TimeText}"
                                               Foreground="{ThemeResource SlMutedTextBrush}"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1"
                                                Spacing="1"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding GameText}"
                                                   Foreground="{ThemeResource SlTextBrush}"/>
                                        <TextBlock Text="{Binding DetailText}"
                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Quantity}"
                                               Foreground="{ThemeResource SlTextBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding AmountText}"
                                               Foreground="{ThemeResource SlTextBrush}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2"
                        Spacing="16">
                <Border Style="{StaticResource SlPanelBorderStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Current Shift"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>

                        <StackPanel Spacing="2">
                            <TextBlock x:Name="RevenueText"
                                       Text="$0.00"
                                       Style="{StaticResource SlMetricTextStyle}"/>
                            <TextBlock Text="Sales amount"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock x:Name="TicketsText"
                                       Text="0"
                                       Style="{StaticResource SlMetricTextStyle}"/>
                            <TextBlock Text="Tickets sold"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>

                        <StackPanel Spacing="2">
                            <TextBlock x:Name="AverageText"
                                       Text="$0.00"
                                       Style="{StaticResource SlMetricTextStyle}"/>
                            <TextBlock Text="Average ticket"
                                       Style="{StaticResource SlCaptionTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SlPanelBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Game Summary"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                        <TextBlock x:Name="GameMixText"
                                   Text="No sales recorded."
                                   Foreground="{ThemeResource SlMutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            </Grid>

            <Grid x:Name="SectionContent"
                  Grid.Column="1"
                  Padding="24"
                  Visibility="Collapsed">
                <Border Style="{StaticResource SlPanelBorderStyle}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="SectionTitleText"
                                   Text="Bins"
                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                        <TextBlock x:Name="SectionDescriptionText"
                                   Text="This section will use the same operational model defined in the product instructions."
                                   Style="{StaticResource SlCaptionTextStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{ThemeResource SlSurfaceBrush}"
                BorderBrush="{ThemeResource SlBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <TextBlock x:Name="StatusText"
                       Text="Ready"
                       Style="{StaticResource SlCaptionTextStyle}"/>
        </Border>
    </Grid>
</Window>
