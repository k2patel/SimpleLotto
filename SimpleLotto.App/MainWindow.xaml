                                                    <TextBlock Text="Shift" Style="{StaticResource SlCaptionTextStyle}"/>
                                                    <TextBlock Grid.Column="1" Text="Closed" Style="{StaticResource SlCaptionTextStyle}"/>
                                                    <TextBlock Grid.Column="2" Text="Sales" Style="{StaticResource SlCaptionTextStyle}"/>
                                                    <TextBlock Grid.Column="3" Text="Tickets" Style="{StaticResource SlCaptionTextStyle}"/>
                                                    <TextBlock Grid.Column="4" Text="Bins" Style="{StaticResource SlCaptionTextStyle}"/>
                                                    <TextBlock Grid.Column="5" Text="Details" Style="{StaticResource SlCaptionTextStyle}"/>
                                                </Grid>
                                                <TextBlock x:Name="ClosingHistoryPageStatusText"
                                                           Grid.Row="2"
                                                           Text="Page 1 of 1"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
