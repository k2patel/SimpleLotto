                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="112"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox x:Name="DisplayBurnInCheckBox"
                                                                  Content="Burn-in protection"
                                                                  IsChecked="True"
                                                                  VerticalAlignment="Center"/>
