                                                          SelectionMode="Single"
                                                          SelectionChanged="ClosingHistoryListView_SelectionChanged"
                                                          SizeChanged="PagedList_SizeChanged">
                                                    <ListView.Resources>
                                                        <SolidColorBrush x:Key="ListViewItemBackgroundSelected"
                                                                         Color="{ThemeResource SlAccent}"
                                                                         Opacity="0.20"/>
                                                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver"
                                                                         Color="{ThemeResource SlAccent}"
                                                                         Opacity="0.26"/>
                                                        <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed"
                                                                         Color="{ThemeResource SlAccent}"
                                                                         Opacity="0.32"/>
                                                    </ListView.Resources>
                                                    <ListView.ItemContainerStyle>
                                                        <Style TargetType="ListViewItem">
                                                            <Setter Property="Margin" Value="0,0,0,4"/>
                                                            <Setter Property="Padding" Value="0"/>
                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        </Style>
                                                    </ListView.ItemContainerStyle>
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid MinHeight="44"
                                                                  Padding="12,8"
                                                                  ColumnSpacing="12">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="140"/>
                                                                    <ColumnDefinition Width="150"/>
                                                                    <ColumnDefinition Width="110"/>
                                                                    <ColumnDefinition Width="90"/>
                                                                    <ColumnDefinition Width="90"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding ShiftText}"
                                                                           Foreground="{ThemeResource SlTextBrush}"
                                                                           HorizontalAlignment="Left"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding ClosedText}"
                                                                           Foreground="{ThemeResource SlTextBrush}"
                                                                           HorizontalAlignment="Left"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding SalesText}"
                                                                           Foreground="{ThemeResource SlTextBrush}"
                                                                           HorizontalAlignment="Left"/>
                                                                <TextBlock Grid.Column="3"
                                                                           Text="{Binding TicketText}"
                                                                           Foreground="{ThemeResource SlTextBrush}"
                                                                           HorizontalAlignment="Left"/>
                                                                <TextBlock Grid.Column="4"
                                                                           Text="{Binding BinText}"
                                                                           Foreground="{ThemeResource SlTextBrush}"
                                                                           HorizontalAlignment="Left"/>
                                                                <TextBlock Grid.Column="5"
                                                                           Text="{Binding ReconciliationText}"
                                                                           Style="{StaticResource SlCaptionTextStyle}"
                                                                           TextWrapping="Wrap"
                                                                           HorizontalAlignment="Left"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Column="1"
                                                Style="{StaticResource SlPanelBorderStyle}">
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <StackPanel Spacing="12">
                                                    <TextBlock Text="Selected Closing Report"
                                                               Style="{StaticResource SlSectionTitleTextStyle}"/>

                                                    <Border Padding="12"
                                                            CornerRadius="6"
                                                            BorderBrush="{ThemeResource SlBorderBrush}"
                                                            BorderThickness="1"
                                                            Background="{ThemeResource SlSurfaceAltBrush}">
                                                        <StackPanel Spacing="8">
                                                            <TextBlock Text="Shift Information"
                                                                       Style="{StaticResource SlCaptionTextStyle}"/>
                                                            <TextBlock x:Name="ClosingReportSummaryText"
                                                                       Text="Select a closing to view report details."
                                                                       Foreground="{ThemeResource SlTextBrush}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Padding="12"
                                                            CornerRadius="6"
                                                            BorderBrush="{ThemeResource SlBorderBrush}"
                                                            BorderThickness="1"
                                                            Background="{ThemeResource SlSurfaceAltBrush}">
                                                        <StackPanel Spacing="8">
                                                            <TextBlock Text="Cash Inputs"
                                                                       Style="{StaticResource SlCaptionTextStyle}"/>
                                                            <TextBlock x:Name="ClosingReportCashText"
                                                                       Text="Online sale: $0.00"
                                                                       Foreground="{ThemeResource SlTextBrush}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Padding="12"
                                                            CornerRadius="6"
                                                            BorderBrush="{ThemeResource SlBorderBrush}"
                                                            BorderThickness="1"
                                                            Background="{ThemeResource SlSurfaceAltBrush}">
                                                        <StackPanel Spacing="8">
                                                            <TextBlock Text="Inventory Reconciliation"
                                                                       Style="{StaticResource SlCaptionTextStyle}"/>
                                                            <TextBlock x:Name="ClosingReportInventoryText"
                                                                       Text="0 closed, 0 updated, 0 resolved"
                                                                       Foreground="{ThemeResource SlTextBrush}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <Border Padding="12"
                                                            CornerRadius="6"
                                                            BorderBrush="{ThemeResource SlBorderBrush}"
                                                            BorderThickness="1"
                                                            Background="{ThemeResource SlSurfaceAltBrush}">
                                                        <StackPanel Spacing="10">
                                                            <TextBlock Text="Files"
                                                                       Style="{StaticResource SlCaptionTextStyle}"/>
                                                            <TextBlock x:Name="ClosingReportStatusText"
                                                                       Text="Select a closing to see its report folder."
                                                                       Style="{StaticResource SlCaptionTextStyle}"
                                                                       TextWrapping="Wrap"/>
                                                            <Button x:Name="OpenSelectedClosingReportButton"
                                                                    Content="Open Reports"
                                                                    HorizontalAlignment="Stretch"
                                                                    IsEnabled="False"
                                                                    Click="OpenClosingReportButton_Click"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </TabViewItem>
                            </TabView>
                        </Grid>

                        <Grid x:Name="SettingsContent"
                              RowSpacing="16"
                              Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Text="Settings"
                                           Style="{StaticResource SlSectionTitleTextStyle}"/>
                                <TextBlock x:Name="SettingsSubtitleText"
                                           Text="Store, users, scanner, display, and game setup controls for the current installation."
                                           Style="{StaticResource SlCaptionTextStyle}"/>
                            </StackPanel>

                            <TabView x:Name="SettingsTabs"
                                     Grid.Row="1"
                                     IsAddTabButtonVisible="False"
                                     CanDragTabs="False"
                                     SelectionChanged="SettingsTabs_SelectionChanged">
                                <TabViewItem x:Name="StoreSettingsTab"
                                             Header="Store"
                                             IsClosable="False">
                                    <Grid RowSpacing="14">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Store"
                                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                                            <TextBlock Text="Store identity and registration status for this installation."
                                                       Style="{StaticResource SlCaptionTextStyle}"/>
                                        </StackPanel>
                                        <Grid Grid.Row="1"
                                              ColumnSpacing="14"
                                              RowSpacing="14">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource SlPanelBorderStyle}">
                                                <StackPanel Spacing="10">
                                                    <TextBlock Text="Store Address"
                                                               Style="{StaticResource SlSectionTitleTextStyle}"/>
                                                    <TextBlock x:Name="SettingsStoreText"
                                                               Text="Store setup not completed."
                                                               Foreground="{ThemeResource SlTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock x:Name="SettingsStateText"
                                                               Text="State: not selected"
                                                               Style="{StaticResource SlCaptionTextStyle}"/>
                                                    <TextBlock x:Name="SettingsBarcodeText"
                                                               Text="Barcode format: not selected"
                                                               Style="{StaticResource SlCaptionTextStyle}"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="1"
                                                    Style="{StaticResource SlPanelBorderStyle}">
                                                <StackPanel Spacing="10">
                                                    <TextBlock Text="Registration"
                                                               Style="{StaticResource SlSectionTitleTextStyle}"/>
                                                    <TextBlock x:Name="LicenseRegistrationText"
                                                               Text="Device registration has not been checked."
                                                               Foreground="{ThemeResource SlTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock x:Name="LicenseLastCheckedText"
                                                               Text="License last checked: never"
                                                               Style="{StaticResource SlCaptionTextStyle}"
                                                               TextWrapping="Wrap"/>
                                                    <Button Content="Check License"
                                                            HorizontalAlignment="Stretch"
                                                            Click="CheckLicenseButton_Click"/>
                                                    <TextBlock x:Name="LicenseStatusText"
                                                               Text="License check uses the WindowsPOS-compatible registration service when available."
                                                               Style="{StaticResource SlCaptionTextStyle}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Row="1"
                                                    Grid.ColumnSpan="2"
                                                    Style="{StaticResource SlPanelBorderStyle}">
                                                <StackPanel Spacing="10">
                                                    <TextBlock Text="Version Information"
                                                               Style="{StaticResource SlSectionTitleTextStyle}"/>
                                                    <Grid ColumnSpacing="18"
                                                          RowSpacing="8">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="170"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="App version"
                                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                                        <TextBlock x:Name="SettingsAppVersionText"
                                                                   Grid.Column="1"
                                                                   Text="App version: unavailable"
                                                                   Foreground="{ThemeResource SlTextBrush}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Row="1"
                                                                   Text="Build version"
                                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                                        <TextBlock x:Name="SettingsBuildVersionText"
                                                                   Grid.Row="1"
                                                                   Grid.Column="1"
                                                                   Text="Build version: unavailable"
                                                                   Foreground="{ThemeResource SlTextBrush}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Row="2"
                                                                   Text="Database schema"
                                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                                        <TextBlock x:Name="SettingsSchemaVersionText"
                                                                   Grid.Row="2"
                                                                   Grid.Column="1"
                                                                   Text="Database schema: unavailable"
                                                                   Foreground="{ThemeResource SlTextBrush}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Row="3"
                                                                   Text="Windows App SDK"
                                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                                        <TextBlock x:Name="SettingsWindowsAppSdkVersionText"
                                                                   Grid.Row="3"
                                                                   Grid.Column="1"
                                                                   Text="Windows App SDK: unavailable"
                                                                   Foreground="{ThemeResource SlTextBrush}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Row="4"
                                                                   Text="Database"
                                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                                        <TextBlock x:Name="SettingsDatabasePathText"
                                                                   Grid.Row="4"
                                                                   Grid.Column="1"
                                                                   Text="Database: unavailable"
                                                                   Foreground="{ThemeResource SlTextBrush}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Row="5"
                                                                   Text="Logs"
                                                                   Style="{StaticResource SlCaptionTextStyle}"/>
                                                        <TextBlock x:Name="SettingsLogPathText"
                                                                   Grid.Row="5"
                                                                   Grid.Column="1"
                                                                   Text="Logs: unavailable"
                                                                   Foreground="{ThemeResource SlTextBrush}"
                                                                   TextWrapping="Wrap"/>
                                                    </Grid>
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Text="Upgrades"
                                                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                                                        <TextBlock x:Name="SettingsUpgradeStatusText"
                                                                   Text="No upgrade check has run."
                                                                   Foreground="{ThemeResource SlTextBrush}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock Text="Automatic startup checks run first-week Monday, second-week Tuesday, third-week Wednesday, and fourth-week Thursday."
                                                                   Style="{StaticResource SlCaptionTextStyle}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock x:Name="SettingsRdisplayUpgradeStatusText"
                                                                   Text="Rdisplay upgrade trigger has not run."
                                                                   Style="{StaticResource SlCaptionTextStyle}"
                                                                   TextWrapping="Wrap"/>
                                                        <StackPanel Orientation="Horizontal"
                                                                    Spacing="8">
                                                            <Button x:Name="CheckUpgradeButton"
                                                                    Content="Check for Upgrade"
                                                                    Click="CheckUpgradeButton_Click"/>
                                                            <Button x:Name="ApplyUpgradeButton"
                                                                    Content="Apply Upgrade"
                                                                    IsEnabled="False"
                                                                    Click="ApplyUpgradeButton_Click"/>
                                                            <Button x:Name="TriggerRdisplayUpgradeButton"
                                                                    Content="Upgrade Rdisplay"
                                                                    Click="TriggerRdisplayUpgradeButton_Click"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </TabViewItem>

                                <TabViewItem x:Name="UserSettingsTab"
                                             Header="Users"
                                             AutomationProperties.AutomationId="UserSettingsTab"
                                             IsClosable="False">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <Grid RowSpacing="14">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Spacing="2">
                                                <TextBlock x:Name="PinSettingsTitleText"
                                                           Text="Users and PINs"
                                                           Style="{StaticResource SlSectionTitleTextStyle}"/>
                                                <TextBlock x:Name="PinSettingsDescriptionText"
                                                           Text="Change your PIN or create/reset the optional Clerk login. Every PIN contains exactly four digits."
                                                           Style="{StaticResource SlCaptionTextStyle}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <Grid Grid.Row="1"
                                                  ColumnSpacing="14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border x:Name="OwnPinPanel"
                                                        Style="{StaticResource SlPanelBorderStyle}">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock x:Name="OwnPinTitleText"
                                                                   Text="Your PIN"
                                                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                                                        <TextBlock x:Name="OwnPinInstructionText"
                                                                   Text="Confirm your current PIN before replacing it."
                                                                   Style="{StaticResource SlCaptionTextStyle}"
                                                                   TextWrapping="Wrap"/>
                                                        <PasswordBox x:Name="CurrentUserPinBox"
                                                                     Header="Current 4-digit PIN"
                                                                     AutomationProperties.AutomationId="CurrentUserPin"
                                                                     MaxLength="4"/>
                                                        <PasswordBox x:Name="NewUserPinBox"
                                                                     Header="New 4-digit PIN"
                                                                     AutomationProperties.AutomationId="NewUserPin"
                                                                     MaxLength="4"/>
                                                        <PasswordBox x:Name="ConfirmUserPinBox"
                                                                     Header="Confirm new PIN"
                                                                     AutomationProperties.AutomationId="ConfirmUserPin"
                                                                     MaxLength="4"/>
                                                        <Button x:Name="ChangeOwnPinButton"
                                                                Content="Change My PIN"
                                                                AutomationProperties.AutomationId="ChangeOwnPin"
                                                                HorizontalAlignment="Stretch"
                                                                Click="ChangeOwnPinButton_Click"/>
                                                        <TextBlock x:Name="OwnPinStatusText"
                                                                   Text="Enter your current and new PINs."
                                                                   Style="{StaticResource SlCaptionTextStyle}"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border x:Name="ClerkResetPanel"
                                                        Grid.Column="1"
                                                        Style="{StaticResource SlPanelBorderStyle}">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="Reset Clerk PIN"
                                                                   Style="{StaticResource SlSectionTitleTextStyle}"/>
                                                        <TextBlock x:Name="ClerkAccountStatusText"
                                                                   Text="No Clerk login is configured."
                                                                   Style="{StaticResource SlCaptionTextStyle}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBox x:Name="ClerkNameSettingsBox"
                                                                 Header="Clerk name"
                                                                 AutomationProperties.AutomationId="ClerkLoginName"
                                                                 MaxLength="64"/>
                                                        <PasswordBox x:Name="NewClerkPinSettingsBox"
                                                                     Header="New 4-digit PIN"
                                                                     AutomationProperties.AutomationId="NewClerkPin"
                                                                     MaxLength="4"/>
                                                        <PasswordBox x:Name="ConfirmClerkPinSettingsBox"
                                                                     Header="Confirm new PIN"
                                                                     AutomationProperties.AutomationId="ConfirmClerkPin"
                                                                     MaxLength="4"/>
                                                        <Button x:Name="ResetClerkPinButton"
                                                                Content="Reset Clerk PIN"
                                                                AutomationProperties.AutomationId="ResetClerkPin"
                                                                HorizontalAlignment="Stretch"
                                                                Click="ResetClerkPinButton_Click"/>
                                                        <TextBlock x:Name="ClerkResetStatusText"
                                                                   Text="Enter a Clerk name and matching four-digit PIN."
                                                                   Style="{StaticResource SlCaptionTextStyle}"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </ScrollViewer>
                                </TabViewItem>

                                <TabViewItem x:Name="ScannerDisplaySettingsTab"
                                             Header="Scanner and Display"
                                             IsClosable="False">
                                    <Grid RowSpacing="14">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Scanner and Display"
                                                       Style="{StaticResource SlSectionTitleTextStyle}"/>
                                            <TextBlock Text="Scanner pairing and Rdisplay registration stay visible for daily support checks."
                                                       Style="{StaticResource SlCaptionTextStyle}"/>
                                        </StackPanel>
                                        <Grid Grid.Row="1"
                                              ColumnSpacing="14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Style="{StaticResource SlPanelBorderStyle}">
                                                <StackPanel Spacing="10">
                                                    <TextBlock Text="Scanner"
                                                               Style="{StaticResource SlSectionTitleTextStyle}"/>
                                                    <TextBlock x:Name="SettingsScannerText"
                                                               Text="Scanner: WindowsPOS global capture model"
                                                               Foreground="{ThemeResource SlTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="Pairing and RawInput background capture will use the WindowsPOS scanner model."
                                                               Style="{StaticResource SlCaptionTextStyle}"
                                                               TextWrapping="Wrap"/>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock x:Name="ScannerPairingStatusText"
                                                                   Text="No scanner paired"
                                                                   Foreground="{ThemeResource SlTextBrush}"
                                                                   TextWrapping="Wrap"/>
                                                        <TextBlock x:Name="ScannerPairingDetailText"
                                                                   Text="Scans only register while the app has focus."
                                                                   Style="{StaticResource SlCaptionTextStyle}"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <NumberBox x:Name="ScanPairTimeoutBox"
                                                               Header="Activation scan timeout"
                                                               Value="5"
                                                               Minimum="1"
                                                               Maximum="30"
                                                               SmallChange="1"
                                                               LargeChange="5"
                                                               SpinButtonPlacementMode="Compact"/>
                                                    <TextBlock Text="Seconds allowed between a bin scan and a bundle or ticket scan."
                                                               Style="{StaticResource SlCaptionTextStyle}"
                                                               TextWrapping="Wrap"/>
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Button x:Name="PairScannerButton"
                                                                Content="Pair scanner"
                                                                HorizontalAlignment="Stretch"
                                                                Click="PairScannerButton_Click"/>
                                                        <Button x:Name="UnpairScannerButton"
                                                                Grid.Column="1"
                                                                Content="Unpair scanner"
                                                                HorizontalAlignment="Stretch"
                                                                Click="UnpairScannerButton_Click"/>
                                                        <Button Grid.Column="2"
                                                                Content="Save"
                                                                HorizontalAlignment="Stretch"
                                                                Click="SaveScannerSettingsButton_Click"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="1"
