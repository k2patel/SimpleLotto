                                                        Spacing="6">
                                                <Border Width="14"
                                                        Height="14"
                                                        CornerRadius="3"
                                                        BorderBrush="{ThemeResource SlBorderBrush}"
                                                        BorderThickness="1"
                                                        Background="{ThemeResource SlBinEmptyBrush}"/>
                                                <TextBlock Text="Unscanned"
                                                           Style="{StaticResource SlCaptionTextStyle}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <GridView x:Name="ClosingBinsGridView"
                                                  Grid.Row="2"
                                                  MinHeight="360"
                                                  IsItemClickEnabled="True"
                                                  ItemClick="ClosingBinsGridView_ItemClick"
